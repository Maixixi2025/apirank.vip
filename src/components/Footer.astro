---
import { t, type Locale } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="bg-gray-900 text-gray-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-1">
        <div class="flex items-center gap-2 mb-4">
          <svg class="w-8 h-8 text-blue-500" viewBox="0 0 32 32" fill="none">
            <rect width="32" height="32" rx="8" fill="currentColor"/>
            <path d="M8 16L14 10L20 16L14 22L8 16Z" fill="white"/>
            <path d="M14 16L20 10L26 16L20 22L14 16Z" fill="white" fill-opacity="0.6"/>
          </svg>
          <span class="font-bold text-lg text-white">APIRank</span>
        </div>
        <p class="text-sm text-gray-400 leading-relaxed">
          {t(locale, 'footer.tagline')}
        </p>
        <p class="text-xs text-gray-500 mt-4">
          © {year} APIRank
        </p>
      </div>
      
      <!-- Links -->
      <div>
        <h3 class="font-semibold text-white mb-3 text-sm">
          {locale === 'zh' ? '热门厂商' : 'Top Providers'}
        </h3>
        <ul class="space-y-2">
          <li><a href={`/${locale}/providers/openai`} class="text-sm text-gray-400 hover:text-blue-400 transition-colors">OpenAI</a></li>
          <li><a href={`/${locale}/providers/anthropic`} class="text-sm text-gray-400 hover:text-blue-400 transition-colors">Anthropic</a></li>
          <li><a href={`/${locale}/providers/google`} class="text-sm text-gray-400 hover:text-blue-400 transition-colors">Google AI</a></li>
          <li><a href={`/${locale}/providers/deepseek`} class="text-sm text-gray-400 hover:text-blue-400 transition-colors">DeepSeek</a></li>
        </ul>
      </div>
      
      <div>
        <h3 class="font-semibold text-white mb-3 text-sm">
          {locale === 'zh' ? '资源' : 'Resources'}
        </h3>
        <ul class="space-y-2">
          <li><a href={`/${locale}/tutorials`} class="text-sm text-gray-400 hover:text-blue-400 transition-colors">{t(locale, 'nav.tutorials')}</a></li>
          <li><a href={`/${locale}/providers`} class="text-sm text-gray-400 hover:text-blue-400 transition-colors">{t(locale, 'nav.providers')}</a></li>
        </ul>
      </div>
      
      <div>
        <h3 class="font-semibold text-white mb-3 text-sm">
          {t(locale, 'nav.about')}
        </h3>
        <ul class="space-y-2">
          <li><a href={`/${locale}/about`} class="text-sm text-gray-400 hover:text-blue-400 transition-colors">{t(locale, 'nav.about')}</a></li>
        </ul>
      </div>
    </div>
    
    <!-- Bottom -->
    <div class="border-t border-gray-800 mt-8 pt-6 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-xs text-gray-500">
        {t(locale, 'footer.disclaimer')}
      </p>
      <div class="flex gap-4">
        <a href={`/${locale}/sitemap.xml`} class="text-xs text-gray-500 hover:text-blue-400">Sitemap</a>
        <a href={`/${locale}/llms.txt`} class="text-xs text-gray-500 hover:text-blue-400">LLMs.txt</a>
      </div>
    </div>
  </div>
</footer>
