---
const footerLinks = {
  'AI 厂商': [
    { label: 'OpenAI', href: '/providers/openai' },
    { label: 'Anthropic', href: '/providers/anthropic' },
    { label: 'Google AI', href: '/providers/google' },
    { label: 'DeepSeek', href: '/providers/deepseek' },
    { label: '阿里云通义', href: '/providers/aliyun' },
  ],
  '资源': [
    { label: '使用教程', href: '/tutorials' },
    { label: 'Token 价格对比', href: '/providers' },
    { label: 'AI 最新资讯', href: '/news' },
  ],
  '关于': [
    { label: '关于我们', href: '/about' },
    { label: '联系我们', href: '/about#contact' },
    { label: '隐私政策', href: '/privacy' },
    { label: '免责声明', href: '/disclaimer' },
  ],
};

const year = new Date().getFullYear();
---

<footer class="bg-gray-900 text-gray-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-1">
        <div class="flex items-center gap-2 mb-4">
          <svg class="w-8 h-8 text-blue-500" viewBox="0 0 32 32" fill="none">
            <rect width="32" height="32" rx="8" fill="currentColor"/>
            <path d="M8 16L14 10L20 16L14 22L8 16Z" fill="white"/>
            <path d="M14 16L20 10L26 16L20 22L14 16Z" fill="white" fill-opacity="0.6"/>
          </svg>
          <span class="font-bold text-lg text-white">APIRank</span>
        </div>
        <p class="text-sm text-gray-400 leading-relaxed">
          专注 AI API 价格对比与深度测评，帮开发者找到最划算的 AI Token 方案。
        </p>
        <p class="text-xs text-gray-500 mt-4">
          京ICP备XXXXXXXX号 | © {year} APIRank
        </p>
      </div>
      
      <!-- Links -->
      {Object.entries(footerLinks).map(([category, links]) => (
        <div>
          <h3 class="font-semibold text-white mb-3 text-sm">{category}</h3>
          <ul class="space-y-2">
            {links.map(link => (
              <li>
                <a href={link.href} class="text-sm text-gray-400 hover:text-blue-400 transition-colors">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    
    <!-- Bottom -->
    <div class="border-t border-gray-800 mt-8 pt-6 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-xs text-gray-500">
        本网站部分内容来自公开数据，价格信息仅供参考，购买前请以官网最新定价为准。
      </p>
      <div class="flex gap-4">
        <a href="/sitemap.xml" class="text-xs text-gray-500 hover:text-blue-400">Sitemap</a>
        <a href="/llms.txt" class="text-xs text-gray-500 hover:text-blue-400">LLMs.txt</a>
      </div>
    </div>
  </div>
</footer>
