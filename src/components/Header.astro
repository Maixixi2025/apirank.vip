---
import { t, type Locale } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

// With prefixDefaultLocale: false, EN is root (no /en prefix), ZH is /zh/...
// stripLangPrefix: /zh/tutorials → /tutorials, /providers → /providers, /zh → /
const stripLangPrefix = (pathname: string) => pathname.replace(/^\/(en|zh)/, '') || '/';

const pathWithoutLang = stripLangPrefix(Astro.url.pathname);
// EN path: root URL (no prefix) → / or /tutorials etc.
// ZH path: always /zh prefix
const enPath = pathWithoutLang === '/' ? '/' : `/${pathWithoutLang.replace(/^\//, '')}`;
const zhPath = `/zh${pathWithoutLang === '/' ? '' : pathWithoutLang}`;

// EN is root (no /en prefix), ZH is /zh/...
const navLinks = locale === 'en'
  ? [
      { href: '/', label: 'Home' },
      { href: '/providers', label: 'Providers' },
      { href: '/tutorials', label: 'Tutorials' },
      { href: '/blog', label: 'Blog' },
      { href: '/about', label: 'About' },
      { href: '/privacy', label: 'Privacy' },
      { href: '/contact', label: 'Contact' },
    ]
  : [
      { href: '/zh', label: '首页' },
      { href: '/zh/providers', label: '全部厂商' },
      { href: '/zh/tutorials', label: '使用教程' },
      { href: '/zh/blog', label: '博客' },
      { href: '/zh/about', label: '关于我们' },
      { href: '/zh/privacy', label: '隐私政策' },
      { href: '/zh/contact', label: '联系我们' },
    ];

const currentPath = Astro.url.pathname.replace(/^\/(en|zh)/, '') || '/';
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur border-b border-gray-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href={`/${locale}`} class="flex items-center gap-2">
        <svg class="w-8 h-8 text-blue-600" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect width="32" height="32" rx="8" fill="currentColor"/>
          <path d="M8 16L14 10L20 16L14 22L8 16Z" fill="white"/>
          <path d="M14 16L20 10L26 16L20 22L14 16Z" fill="white" fill-opacity="0.6"/>
        </svg>
        <span class="font-bold text-xl text-gray-900">APIRank</span>
      </a>
      
      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-8">
        {navLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              'text-sm font-medium transition-colors',
              currentPath === link.href.replace(/^\/(en|zh)/, '') || currentPath === link.href
                ? 'text-blue-600'
                : 'text-gray-600 hover:text-blue-600'
            ]}
          >
            {link.label}
          </a>
        ))}
      </nav>
      
      <!-- Lang Switch + CTA -->
      <div class="flex items-center gap-3">
        <div class="flex items-center gap-1 text-xs border border-gray-200 rounded-md p-0.5">
          <a
            href={enPath}
            class:list={['px-2 py-1 rounded font-medium transition-colors', locale === 'en' ? 'bg-blue-600 text-white' : 'text-gray-500 hover:text-blue-600']}
          >
            EN
          </a>
          <a
            href={zhPath}
            class:list={['px-2 py-1 rounded font-medium transition-colors', locale === 'zh' ? 'bg-blue-600 text-white' : 'text-gray-500 hover:text-blue-600']}
          >
            中文
          </a>
        </div>
        <a href={`/${locale}/go/deepseek`} class="btn-primary text-sm py-1.5 px-3">
          {locale === 'zh' ? '免费试用' : 'Try Free'}
        </a>
      </div>
    </div>
  </div>
</header>
