---
import BaseLayout from '../../layouts/BaseLayout.astro';
import providers from '../../data/providers.json';

const sortedProviders = [...providers].sort((a, b) => a.overallRank - b.overallRank);
---

<BaseLayout
  title="AI API Providers Price Comparison | APIRank"
  description="Compare pricing, models, and features across all major AI API providers including OpenAI, Anthropic, Google, DeepSeek, Alibaba, Baidu, Tencent, ByteDance, and more."
>
  <div class="bg-gray-50 border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <nav class="flex items-center gap-2 text-sm text-gray-500">
        <a href="/" class="hover:text-blue-600">Home</a>
        <span>›</span>
        <span class="text-gray-900 font-medium">Providers</span>
      </nav>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="text-center mb-10">
      <h1 class="text-3xl font-bold text-gray-900 mb-3">AI API Providers</h1>
      <p class="text-gray-600">Compare pricing, models, and features across all major AI API providers</p>
    </div>

    <div class="mb-12 overflow-x-auto">
      <table class="table-token bg-white rounded-xl overflow-hidden shadow-sm">
        <thead>
          <tr class="bg-gray-50">
            <th>#</th><th>Provider</th><th>Popular Models</th><th>Input</th><th>Output</th><th>China Available</th><th>Free Tier</th><th></th>
          </tr>
        </thead>
        <tbody>
          {sortedProviders.map((p) => (
            <tr>
              <td><span class={`badge text-xs ${p.overallRank <= 3 ? 'badge-success' : 'bg-gray-100 text-gray-600'}`}>#{p.overallRank}</span></td>
              <td class="font-semibold text-gray-900">{p.nameCn}</td>
              <td class="text-gray-600 text-sm">{p.models.slice(0, 2).join(', ')}</td>
              <td class="font-mono text-sm">{p.pricing.input}</td>
              <td class="font-mono text-sm">{p.pricing.output}</td>
              <td><span class={`badge text-xs ${p.availabilityCN.includes('✅') ? 'badge-success' : p.availabilityCN.includes('⚠️') ? 'badge-warning' : 'badge-danger'}`}>{p.availabilityCN}</span></td>
              <td class="text-xs text-gray-500">{p.freeTier}</td>
              <td><a href={`/providers/${p.id}`} class="text-blue-600 hover:text-blue-800 text-sm font-medium">View Details →</a></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</BaseLayout>
