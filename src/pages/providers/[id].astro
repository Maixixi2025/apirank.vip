---
import BaseLayout from '../../layouts/BaseLayout.astro';
import providers from '../../data/providers.json';

export function getStaticPaths() {
  return providers.map(p => ({
    params: { id: p.id },
    props: { provider: p },
  }));
}

const { provider } = Astro.props;
const { id, name, nameCn, website, models, modelCount, pricing, freeTier, paidModel, availabilityCN, highlights, cons, bestFor, affiliateUrl } = provider;

const rankLabel = provider.overallRank <= 3 ? '⭐⭐⭐ Highly Recommended' : provider.overallRank <= 6 ? '⭐⭐ Recommended' : '⭐ Consider';

const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": `${provider.name} API`,
  "description": `${provider.nameCn} AI API - ${provider.highlights.join('; ')}`,
  "brand": { "@type": "Brand", "name": provider.name },
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": provider.category === 'international' ? 'USD' : 'CNY',
    "availability": "https://schema.org/InStock"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": provider.overallRank <= 3 ? "5" : provider.overallRank <= 6 ? "4" : "3",
    "bestRating": "5"
  }
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://apirank.vip" },
    { "@type": "ListItem", "position": 2, "name": "Providers", "item": "https://apirank.vip/providers" },
    { "@type": "ListItem", "position": 3, "name": provider.nameCn, "item": `https://apirank.vip/providers/${provider.id}` }
  ]
};
---

<BaseLayout
  title={`${nameCn} API Price & Review (${new Date().getFullYear()}) | APIRank`}
  description={`Complete review of ${nameCn} (${name}) API: pricing, free tier, China accessibility, model comparison. ${highlights[0]}. Find the best ${nameCn} Token plan at APIRank.`}
  type="article"
>
  <script type="application/ld+json" set:html={JSON.stringify(productJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />

  <!-- Breadcrumb -->
  <div class="bg-gray-50 border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <nav class="flex items-center gap-2 text-sm text-gray-500">
        <a href="/" class="hover:text-blue-600">Home</a>
        <span>›</span>
        <a href="/providers" class="hover:text-blue-600">Providers</a>
        <span>›</span>
        <span class="text-gray-900 font-medium">{nameCn}</span>
      </nav>
    </div>
  </div>

  <article class="py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        <div class="lg:col-span-2 space-y-8">
          
          <header>
            <div class="flex items-start justify-between gap-4 mb-4">
              <div>
                <h1 class="text-3xl font-bold text-gray-900 mb-2">{nameCn} <span class="text-gray-400 font-normal text-xl">({name})</span></h1>
                <p class="text-gray-500">Listed at <a href={website} target="_blank" rel="noopener" class="text-blue-600 hover:underline">{website}</a></p>
              </div>
              <div class="flex flex-col items-end gap-2">
                <span class="text-sm text-gray-500">Overall Rank</span>
                <span class="text-2xl font-bold text-blue-600">#{provider.overallRank}</span>
                <span class="text-xs text-yellow-600">{rankLabel}</span>
              </div>
            </div>
            
            <div class={`inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-sm font-medium ${
              availabilityCN.includes('✅') ? 'bg-green-100 text-green-800' :
              availabilityCN.includes('⚠️') ? 'bg-yellow-100 text-yellow-800' :
              'bg-red-100 text-red-800'
            }`}>
              <span>{availabilityCN}</span>
              <span class="text-gray-400">|</span>
              <span>{provider.category === 'domestic' ? '🇨🇳 China Direct' : '🌍 International'}</span>
            </div>
          </header>

          <div class="adsense-placeholder h-24 rounded-lg"></div>

          <!-- Pricing Table -->
          <section class="bg-white rounded-xl border border-gray-200 p-6">
            <h2 class="text-xl font-bold text-gray-900 mb-4">💰 Token Pricing</h2>
            <table class="table-token">
              <thead><tr><th>Type</th><th>Price</th><th>Note</th></tr></thead>
              <tbody>
                <tr>
                  <td class="font-medium">Input</td>
                  <td class="font-mono font-semibold text-blue-600">{pricing.input}</td>
                  <td class="text-gray-500 text-sm">per million tokens</td>
                </tr>
                <tr>
                  <td class="font-medium">Output</td>
                  <td class="font-mono font-semibold text-green-600">{pricing.output}</td>
                  <td class="text-gray-500 text-sm">per million tokens</td>
                </tr>
                {pricing.cacheRead && (<tr><td class="font-medium">Cache Read</td><td class="font-mono">{pricing.cacheRead}</td><td class="text-gray-500 text-sm">Discounted</td></tr>)}
                {pricing.cacheWrite && (<tr><td class="font-medium">Cache Write</td><td class="font-mono">{pricing.cacheWrite}</td><td class="text-gray-500 text-sm">Discounted</td></tr>)}
              </tbody>
            </table>
            <div class="mt-4 p-4 bg-blue-50 rounded-lg">
              <span class="text-sm font-semibold text-blue-800">💡 Free Credits: {freeTier}</span>
            </div>
          </section>

          <!-- Models -->
          <section class="bg-white rounded-xl border border-gray-200 p-6">
            <h2 class="text-xl font-bold text-gray-900 mb-4">🤖 Supported Models ({modelCount})</h2>
            <div class="flex flex-wrap gap-2">
              {models.map(model => (
                <span class="inline-block bg-gray-100 text-gray-700 px-3 py-1 rounded-full text-sm font-mono">{model}</span>
              ))}
            </div>
          </section>

          <!-- Highlights -->
          <section class="bg-white rounded-xl border border-gray-200 p-6">
            <h2 class="text-xl font-bold text-gray-900 mb-4">✨ Pros</h2>
            <ul class="space-y-3">
              {highlights.map(h => (<li class="flex items-start gap-3"><span class="text-green-500 mt-0.5">✓</span><span class="text-gray-700">{h}</span></li>))}
            </ul>
          </section>

          <!-- Cons -->
          <section class="bg-white rounded-xl border border-gray-200 p-6">
            <h2 class="text-xl font-bold text-gray-900 mb-4">⚠️ Cons</h2>
            <ul class="space-y-3">
              {cons.map(c => (<li class="flex items-start gap-3"><span class="text-red-500 mt-0.5">×</span><span class="text-gray-700">{c}</span></li>))}
            </ul>
          </section>

          <!-- Best For -->
          <section class="bg-indigo-50 rounded-xl border border-indigo-100 p-6">
            <h2 class="text-xl font-bold text-indigo-900 mb-3">🎯 Best For</h2>
            <p class="text-indigo-800">{bestFor}</p>
          </section>

          <div class="adsense-placeholder h-24 rounded-lg"></div>
        </div>

        <!-- Sidebar -->
        <aside class="space-y-6">
          <div class="bg-white rounded-xl border border-gray-200 p-6 sticky top-20">
            <h3 class="font-bold text-gray-900 mb-3">Get Started with {nameCn}</h3>
            <p class="text-sm text-gray-500 mb-4">{freeTier}</p>
            
            {affiliateUrl ? (
              <a href={affiliateUrl} target="_blank" rel="noopener" class="btn-primary w-full text-center block">Get API Key →</a>
            ) : (
              <a href={website} target="_blank" rel="noopener" class="btn-primary w-full text-center block">Visit Official Site →</a>
            )}
            
            <div class="mt-4 pt-4 border-t border-gray-100 text-xs text-gray-400">
              <p>Prices updated {new Date().toLocaleDateString('en-US')}</p>
              <p class="mt-1">Check official site for latest pricing</p>
            </div>
          </div>

          <div class="bg-white rounded-xl border border-gray-200 p-6">
            <h3 class="font-bold text-gray-900 mb-4">⚡ Quick Stats</h3>
            <div class="space-y-3 text-sm">
              <div class="flex justify-between"><span class="text-gray-500">Overall Rank</span><span class="font-semibold">#{provider.overallRank}</span></div>
              <div class="flex justify-between"><span class="text-gray-500">Models</span><span class="font-semibold">{modelCount}+</span></div>
              <div class="flex justify-between"><span class="text-gray-500">China Access</span><span class={availabilityCN.includes('✅') ? 'text-green-600 font-semibold' : 'text-red-500'}>{availabilityCN}</span></div>
              <div class="flex justify-between"><span class="text-gray-500">Price Level</span><span class="font-semibold">{'★'.repeat(provider.priceRank)}</span></div>
              <div class="flex justify-between"><span class="text-gray-500">Speed/Stability</span><span class="font-semibold">{'★'.repeat(provider.speedRank)}</span></div>
            </div>
          </div>

          <div class="bg-white rounded-xl border border-gray-200 p-6">
            <h3 class="font-bold text-gray-900 mb-4">Other Providers</h3>
            <div class="space-y-2">
              {providers.filter(p => p.id !== id).sort((a, b) => a.overallRank - b.overallRank).slice(0, 5).map(p => (
                <a href={`/providers/${p.id}`} class="flex items-center justify-between py-2 text-sm hover:text-blue-600 transition-colors">
                  <span>{p.nameCn}</span><span class="text-gray-400">#{p.overallRank}</span>
                </a>
              ))}
              <a href="/providers" class="block text-center text-blue-600 text-sm font-medium py-2 hover:underline">View All →</a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </article>
</BaseLayout>
