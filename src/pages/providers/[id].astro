---
import BaseLayout from '../../layouts/BaseLayout.astro';
import providers from '../../data/providers.json';

export function getStaticPaths() {
  return providers.map(p => ({
    params: { id: p.id },
    props: { provider: p },
  }));
}

const { provider } = Astro.props;

// JSON-LD: Product schema
const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": `${provider.name} API`,
  "description": `${provider.nameCn} AI API - ${provider.highlights.join('; ')}`,
  "brand": {
    "@type": "Brand",
    "name": provider.name
  },
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": provider.category === 'international' ? 'USD' : 'CNY',
    "availability": "https://schema.org/InStock"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": provider.overallRank <= 3 ? "5" : provider.overallRank <= 6 ? "4" : "3",
    "bestRating": "5"
  }
};

// JSON-LD: BreadcrumbList
const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "首页", "item": "https://apirank.vip" },
    { "@type": "ListItem", "position": 2, "name": "AI 厂商", "item": "https://apirank.vip/providers" },
    { "@type": "ListItem", "position": 3, "name": provider.nameCn, "item": `https://apirank.vip/providers/${provider.id}` }
  ]
};

const { id, name, nameCn, website, models, modelCount, pricing, freeTier, paidModel, availabilityCN, highlights, cons, bestFor, affiliateUrl } = provider;

const rankLabel = provider.overallRank <= 3 ? '⭐⭐⭐ 强烈推荐' : provider.overallRank <= 6 ? '⭐⭐ 推荐' : '⭐ 可考虑';
---

<BaseLayout
  title={`${nameCn} API 价格与测评 (${new Date().getFullYear()}) | APIRank`}
  description={`${nameCn}（${name}）API 完整测评：价格、免费额度、国内可用性、模型对比。${highlights[0]}。找最划算的 ${nameCn} Token 方案，就在 APIRank。`}
  type="article"
>
  <script type="application/ld+json" set:html={JSON.stringify(productJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />

  <!-- Breadcrumb -->
  <div class="bg-gray-50 border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <nav class="flex items-center gap-2 text-sm text-gray-500">
        <a href="/" class="hover:text-blue-600">首页</a>
        <span>›</span>
        <a href="/providers" class="hover:text-blue-600">AI 厂商</a>
        <span>›</span>
        <span class="text-gray-900 font-medium">{nameCn}</span>
      </nav>
    </div>
  </div>

  <article class="py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-8">
          
          <!-- Header -->
          <header>
            <div class="flex items-start justify-between gap-4 mb-4">
              <div>
                <h1 class="text-3xl font-bold text-gray-900 mb-2">
                  {nameCn} <span class="text-gray-400 font-normal text-xl">({name})</span>
                </h1>
                <p class="text-gray-500">
                  收录于 <a href={website} target="_blank" rel="noopener" class="text-blue-600 hover:underline">{website}</a>
                </p>
              </div>
              <div class="flex flex-col items-end gap-2">
                <span class="text-sm text-gray-500">综合排名</span>
                <span class="text-2xl font-bold text-blue-600">#{provider.overallRank}</span>
                <span class="text-xs text-yellow-600">{rankLabel}</span>
              </div>
            </div>
            
            <!-- Availability Badge -->
            <div class={`inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-sm font-medium ${
              availabilityCN.includes('✅') ? 'bg-green-100 text-green-800' :
              availabilityCN.includes('⚠️') ? 'bg-yellow-100 text-yellow-800' :
              'bg-red-100 text-red-800'
            }`}>
              <span>{availabilityCN}</span>
              <span class="text-gray-400">|</span>
              <span>{provider.category === 'domestic' ? '🇨🇳 国内可用' : '🌍 国际'}</span>
            </div>
          </header>

          <!-- AdSense -->
          <div class="adsense-placeholder h-24 rounded-lg"></div>

          <!-- Pricing Table -->
          <section class="bg-white rounded-xl border border-gray-200 p-6">
            <h2 class="text-xl font-bold text-gray-900 mb-4">💰 Token 价格</h2>
            
            <table class="table-token">
              <thead>
                <tr>
                  <th>类型</th>
                  <th>价格</th>
                  <th>备注</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td class="font-medium">输入 (Input)</td>
                  <td class="font-mono font-semibold text-blue-600">{pricing.input}</td>
                  <td class="text-gray-500 text-sm">每百万 tokens</td>
                </tr>
                <tr>
                  <td class="font-medium">输出 (Output)</td>
                  <td class="font-mono font-semibold text-green-600">{pricing.output}</td>
                  <td class="text-gray-500 text-sm">每百万 tokens</td>
                </tr>
                {pricing.cacheRead && (
                  <tr>
                    <td class="font-medium">缓存读取 (Cache Read)</td>
                    <td class="font-mono">{pricing.cacheRead}</td>
                    <td class="text-gray-500 text-sm">享折扣</td>
                  </tr>
                )}
                {pricing.cacheWrite && (
                  <tr>
                    <td class="font-medium">缓存写入 (Cache Write)</td>
                    <td class="font-mono">{pricing.cacheWrite}</td>
                    <td class="text-gray-500 text-sm">享折扣</td>
                  </tr>
                )}
              </tbody>
            </table>
            
            <div class="mt-4 p-4 bg-blue-50 rounded-lg">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-sm font-semibold text-blue-800">💡 免费额度</span>
              </div>
              <p class="text-blue-700">{freeTier}</p>
            </div>
          </section>

          <!-- Models -->
          <section class="bg-white rounded-xl border border-gray-200 p-6">
            <h2 class="text-xl font-bold text-gray-900 mb-4">🤖 支持模型（共 {modelCount} 个）</h2>
            <div class="flex flex-wrap gap-2">
              {models.map(model => (
                <span class="inline-block bg-gray-100 text-gray-700 px-3 py-1 rounded-full text-sm font-mono">
                  {model}
                </span>
              ))}
            </div>
          </section>

          <!-- Highlights -->
          <section class="bg-white rounded-xl border border-gray-200 p-6">
            <h2 class="text-xl font-bold text-gray-900 mb-4">✨ 优势</h2>
            <ul class="space-y-3">
              {highlights.map(h => (
                <li class="flex items-start gap-3">
                  <span class="text-green-500 mt-0.5">✓</span>
                  <span class="text-gray-700">{h}</span>
                </li>
              ))}
            </ul>
          </section>

          <!-- Cons -->
          <section class="bg-white rounded-xl border border-gray-200 p-6">
            <h2 class="text-xl font-bold text-gray-900 mb-4">⚠️ 不足</h2>
            <ul class="space-y-3">
              {cons.map(c => (
                <li class="flex items-start gap-3">
                  <span class="text-red-500 mt-0.5">×</span>
                  <span class="text-gray-700">{c}</span>
                </li>
              ))}
            </ul>
          </section>

          <!-- Best For -->
          <section class="bg-indigo-50 rounded-xl border border-indigo-100 p-6">
            <h2 class="text-xl font-bold text-indigo-900 mb-3">🎯 适合场景</h2>
            <p class="text-indigo-800">{bestFor}</p>
          </section>

          <!-- AdSense -->
          <div class="adsense-placeholder h-24 rounded-lg"></div>

          <!-- FAQ -->
          <section>
            <h2 class="text-xl font-bold text-gray-900 mb-4">❓ 常见问题</h2>
            <div class="space-y-3">
              <details class="bg-white rounded-lg border border-gray-200 p-4 group">
                <summary class="font-semibold text-gray-900 cursor-pointer list-none flex justify-between items-center">
                  如何申请 {nameCn} API Key？
                  <span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
                </summary>
                <p class="mt-3 text-gray-600">
                  访问 {website} 注册账号，完成实名认证（国内平台）后，在控制台创建 API Key。
                  具体操作请参考我们的使用教程。
                </p>
              </details>
              <details class="bg-white rounded-lg border border-gray-200 p-4 group">
                <summary class="font-semibold text-gray-900 cursor-pointer list-none flex justify-between items-center">
                  {nameCn} 支持国内直连吗？
                  <span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
                </summary>
                <p class="mt-3 text-gray-600">
                  {availabilityCN}
                  {provider.category === 'international' ? '国内需要使用代理服务访问。' : '可以直接调用，速度快，延迟低。'}
                </p>
              </details>
            </div>
          </section>
        </div>

        <!-- Sidebar -->
        <aside class="space-y-6">
          
          <!-- CTA Card -->
          <div class="bg-white rounded-xl border border-gray-200 p-6 sticky top-20">
            <h3 class="font-bold text-gray-900 mb-3">立即使用 {nameCn}</h3>
            <p class="text-sm text-gray-500 mb-4">{freeTier}</p>
            
            {affiliateUrl ? (
              <a href={affiliateUrl} target="_blank" rel="noopener" class="btn-primary w-full text-center block">
                获取 API Key →
              </a>
            ) : (
              <a href={website} target="_blank" rel="noopener" class="btn-primary w-full text-center block">
                访问官网 →
              </a>
            )}
            
            <div class="mt-4 pt-4 border-t border-gray-100 text-xs text-gray-400">
              <p>价格信息更新于 {new Date().toLocaleDateString('zh-CN')}</p>
              <p class="mt-1">实际价格以官网最新定价为准</p>
            </div>
          </div>

          <!-- Quick Compare -->
          <div class="bg-white rounded-xl border border-gray-200 p-6">
            <h3 class="font-bold text-gray-900 mb-4">⚡ 快速对比</h3>
            <div class="space-y-3 text-sm">
              <div class="flex justify-between">
                <span class="text-gray-500">综合排名</span>
                <span class="font-semibold">#{provider.overallRank}</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-500">模型数量</span>
                <span class="font-semibold">{modelCount}+</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-500">国内可用</span>
                <span class={availabilityCN.includes('✅') ? 'text-green-600 font-semibold' : 'text-red-500'}>
                  {availabilityCN}
                </span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-500">价格水平</span>
                <span class="font-semibold">{'★'.repeat(provider.priceRank)}</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-500">速度/稳定</span>
                <span class="font-semibold">{'★'.repeat(provider.speedRank)}</span>
              </div>
            </div>
          </div>

          <!-- Other Providers -->
          <div class="bg-white rounded-xl border border-gray-200 p-6">
            <h3 class="font-bold text-gray-900 mb-4">其他厂商</h3>
            <div class="space-y-2">
              {providers
                .filter(p => p.id !== id)
                .sort((a, b) => a.overallRank - b.overallRank)
                .slice(0, 5)
                .map(p => (
                  <a href={`/providers/${p.id}`} class="flex items-center justify-between py-2 text-sm hover:text-blue-600 transition-colors">
                    <span>{p.nameCn}</span>
                    <span class="text-gray-400">#{p.overallRank}</span>
                  </a>
                ))}
              <a href="/providers" class="block text-center text-blue-600 text-sm font-medium py-2 hover:underline">
                查看全部 →
              </a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </article>
</BaseLayout>
