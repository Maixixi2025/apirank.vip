<td class="px-4 py-2 text-sm text-gray-700 border-b">Self-managed</td>
<td class="px-4 py-2 text-sm text-gray-700 border-b">Unlimited</td>
</tr>
<tr class="hover:bg-gray-50">
<td class="px-4 py-2 text-sm text-gray-700 border-b"><strong>Self-host option</strong></td>
