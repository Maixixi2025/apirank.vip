<tr class="hover:bg-gray-50"><td class="px-4 py-2 text-sm text-gray-700 border-b">GPT-4o-mini</td><td class="px-4 py-2 text-sm text-gray-700 border-b">$0.15</td><td class="px-4 py-2 text-sm text-gray-700 border-b">$0.60</td><td class="px-4 py-2 text-sm text-gray-700 border-b">Best price-performance</td></tr>
<tr class="hover:bg-gray-50"><td class="px-4 py-2 text-sm text-gray-700 border-b">o1</td><td class="px-4 py-2 text-sm text-gray-700 border-b">$15.00</td><td class="px-4 py-2 text-sm text-gray-700 border-b">$60.00</td><td class="px-4 py-2 text-sm text-gray-700 border-b">Advanced reasoning</td></tr>
