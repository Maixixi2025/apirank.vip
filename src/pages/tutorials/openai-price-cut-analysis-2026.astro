         "key_var": "DEEPSEEK_API_KEY",
         "model": "deepseek-chat"}},
        # OpenAI fallback — most expensive
        {&#123;"url": "https://api.openai.com/v1/chat/completions",
         "key_var": "OPENAI_API_KEY",
