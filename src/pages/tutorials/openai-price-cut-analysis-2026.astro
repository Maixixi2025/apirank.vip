<div class="overflow-x-auto my-6"><table class="min-w-full divide-y divide-gray-200 border border-gray-200"><thead><tr><th class="px-4 py-2 text-left text-xs font-semibold text-gray-700 border-b">Model</th><th class="px-4 py-2 text-left text-xs font-semibold text-gray-700 border-b">Input (per 1M tokens)</th><th class="px-4 py-2 text-left text-xs font-semibold text-gray-700 border-b">Output (per 1M tokens)</th><th class="px-4 py-2 text-left text-xs font-semibold text-gray-700 border-b">Notes</th></tr></thead><tbody>
