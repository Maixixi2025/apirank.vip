              <tr><td>High-volume simple tasks</td><td>Hunyuan-Lite</td><td>Lowest cost at ¥0.006/1K tokens</td></tr>
              <tr><td>Complex reasoning tasks</td><td>Hunyuan-Pro</td><td>Most capable Hunyuan model</td></tr>
              <tr><td>Tencent Cloud integrated apps</td><td>Hunyuan-Standard</td><td>Single console management</td></tr>
            </tbody>
          </table>
        </div>
      </section>

