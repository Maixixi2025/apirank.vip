<BaseLayout
  title="AI API Tutorials - Getting Started | APIRank"
  description="Step-by-step guides and in-depth comparisons to help you choose the right AI API. DeepSeek vs OpenAI, pricing guides, and more."
>
  <div class="bg-gray-50 border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <nav class="flex items-center gap-2 text-sm text-gray-500">
        <a href="/" class="hover:text-blue-600">Home</a>
        <span>›</span>
        <span class="text-gray-900 font-medium">Tutorials</span>
      </nav>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="text-center mb-12">
      <h1 class="text-3xl font-bold text-gray-900 mb-3">AI API Tutorials</h1>
      <p class="text-gray-600">In-depth reviews and comparisons to help you choose the right AI API</p>
    </div>

    <div class="space-y-6">
      {sortedTutorials.map((t) => (
        <a href={`/tutorials/${t.slug}`} class="block bg-white rounded-xl border border-gray-200 p-6 hover:border-blue-300 hover:shadow-md transition-all">
          <div class="flex items-center gap-4 mb-3">
            <div class="text-3xl">{t.emoji}</div>
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-1">
                <span class="badge badge-primary text-xs">{t.tag}</span>
                <span class="text-xs text-gray-400">{t.date}</span>
                <span class="text-xs text-gray-400">•</span>
                <span class="text-xs text-gray-400">{t.readTime} read</span>
              </div>
              <h2 class="text-lg font-bold text-gray-900">{t.title}</h2>
            </div>
          </div>
          <p class="text-gray-500 text-sm">{t.description}</p>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
