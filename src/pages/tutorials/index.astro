---
import BaseLayout from '../../layouts/BaseLayout.astro';

const tutorials = [
  {
    id: 'deepseek-getting-started',
    title: 'DeepSeek API 入门：从零开始调用',
    desc: '手把手教你注册 DeepSeek 账号、获取 API Key、完成首次 API 调用，含 Python 示例代码。',
    provider: 'DeepSeek',
    level: '入门',
    readTime: '5 分钟',
  },
  {
    id: 'openai-proxy-china',
    title: '国内用户如何稳定调用 OpenAI API',
    desc: '介绍几种国内访问 OpenAI API 的稳定方案：代理服务、API 反代平台、API 转发服务。',
    provider: 'OpenAI',
    level: '进阶',
    readTime: '8 分钟',
  },
  {
    id: 'api-cost-optimization',
    title: 'AI API 成本优化指南：省 50% 费用的 10 个技巧',
    desc: '从模型选择、提示词压缩、缓存策略、并发控制等 10 个维度，全面降低 AI API 调用成本。',
    provider: '通用',
    level: '进阶',
    readTime: '12 分钟',
  },
  {
    id: 'best-ai-api-2025',
    title: '2025 年最值得使用的 AI API 推荐',
    desc: '根据模型能力、价格、速度、生态等维度，综合评选最适合国内开发者的 AI API 方案。',
    provider: '通用',
    level: '入门',
    readTime: '10 分钟',
  },
];
---

<BaseLayout
  title="AI API 使用教程 | APIRank"
  description="AI API 入门教程与进阶指南。涵盖 DeepSeek、OpenAI、各大厂商 API 的注册、调用、成本优化等实战内容。"
>
  <div class="bg-gray-50 border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <nav class="flex items-center gap-2 text-sm text-gray-500">
        <a href="/" class="hover:text-blue-600">首页</a>
        <span>›</span>
        <span class="text-gray-900 font-medium">使用教程</span>
      </nav>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="text-center mb-10">
      <h1 class="text-3xl font-bold text-gray-900 mb-3">AI API 使用教程</h1>
      <p class="text-gray-600">从入门到精通，覆盖主流平台实战指南</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {tutorials.map(t => (
        <a href={`/tutorials/${t.id}`} class="card p-6 group">
          <div class="flex items-center gap-2 mb-3">
            <span class="badge bg-blue-100 text-blue-700">{t.provider}</span>
            <span class={`badge ${t.level === '入门' ? 'bg-green-100 text-green-700' : 'bg-yellow-100 text-yellow-700'}`}>
              {t.level}
            </span>
            <span class="text-xs text-gray-400 ml-auto">{t.readTime}</span>
          </div>
          <h3 class="font-bold text-gray-900 group-hover:text-blue-600 transition-colors mb-2">
            {t.title}
          </h3>
          <p class="text-gray-600 text-sm leading-relaxed">{t.desc}</p>
          <div class="mt-4 text-blue-600 text-sm font-medium">
            阅读全文 →
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
