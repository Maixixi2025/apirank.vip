<h3 class="text-xl font-bold text-gray-900 mt-6 mb-3">3. Make your first call</h3>

<pre><code class="language-python">import os
from openai import OpenAI

client = OpenAI(
    api_key=os.environ["TOGETHER_API_KEY"],
