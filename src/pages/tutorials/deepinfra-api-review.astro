---
import BaseLayout from '../../layouts/BaseLayout.astro';

const slug = 'deepinfra-api-review';
const date = '2026-06-05';
const locale = 'en';

const enTitle = 'DeepInfra API Review 2026: 50+ Models, Lowest LLM Pricing';
const enDescription = 'DeepInfra API review 2026: 50+ open-source models from $0.04/M tok. Llama 3.3 70B at $0.35/M, DeepSeek V3, OpenAI-compatible, batch 50% off. Compare to Together AI & Groq.';
const canonicalUrl = `https://apirank.vip/tutorials/${slug}`;
const zhCanonicalUrl = `https://apirank.vip/zh/tutorials/${slug}`;

const articleJsonLd = {
