    <tr><td class="border border-gray-200 px-3 py-2 text-sm">Mistral Large 2</td><td class="border border-gray-200 px-3 py-2 text-sm">$2.40</td><td class="border border-gray-200 px-3 py-2 text-sm">34.3x</td></tr>
