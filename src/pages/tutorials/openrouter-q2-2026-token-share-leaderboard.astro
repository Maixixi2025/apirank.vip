  <thead><tr><th class="border border-gray-200 px-3 py-2 bg-gray-50 text-left text-sm font-semibold">Rank</th><th class="border border-gray-200 px-3 py-2 bg-gray-50 text-left text-sm font-semibold">Model</th><th class="border border-gray-200 px-3 py-2 bg-gray-50 text-left text-sm font-semibold">Provider</th><th class="border border-gray-200 px-3 py-2 bg-gray-50 text-left text-sm font-semibold">Token Share</th><th class="border border-gray-200 px-3 py-2 bg-gray-50 text-left text-sm font-semibold">Change vs. May</th><th class="border border-gray-200 px-3 py-2 bg-gray-50 text-left text-sm font-semibold">$/1M (in)</th><th class="border border-gray-200 px-3 py-2 bg-gray-50 text-left text-sm font-semibold">$/1M (out)</th></tr></thead>
  <tbody>
    <tr><td class="border border-gray-200 px-3 py-2 text-sm">1</td><td class="border border-gray-200 px-3 py-2 text-sm">DeepSeek V3</td><td class="border border-gray-200 px-3 py-2 text-sm">DeepSeek</td><td class="border border-gray-200 px-3 py-2 text-sm">24.1%</td><td class="border border-gray-200 px-3 py-2 text-sm">+0.4 pp</td><td class="border border-gray-200 px-3 py-2 text-sm">$0.14</td><td class="border border-gray-200 px-3 py-2 text-sm">$0.28</td></tr>
    <tr><td class="border border-gray-200 px-3 py-2 text-sm">2</td><td class="border border-gray-200 px-3 py-2 text-sm">Claude Sonnet 4.5</td><td class="border border-gray-200 px-3 py-2 text-sm">Anthropic</td><td class="border border-gray-200 px-3 py-2 text-sm">16.8%</td><td class="border border-gray-200 px-3 py-2 text-sm">+2.1 pp</td><td class="border border-gray-200 px-3 py-2 text-sm">$3.00</td><td class="border border-gray-200 px-3 py-2 text-sm">$15.00</td></tr>
    <tr><td class="border border-gray-200 px-3 py-2 text-sm">3</td><td class="border border-gray-200 px-3 py-2 text-sm">Claude Opus 4.8</td><td class="border border-gray-200 px-3 py-2 text-sm">Anthropic</td><td class="border border-gray-200 px-3 py-2 text-sm">9.2%</td><td class="border border-gray-200 px-3 py-2 text-sm">NEW (Apr)</td><td class="border border-gray-200 px-3 py-2 text-sm">$15.00</td><td class="border border-gray-200 px-3 py-2 text-sm">$75.00</td></tr>
    <tr><td class="border border-gray-200 px-3 py-2 text-sm">4</td><td class="border border-gray-200 px-3 py-2 text-sm">Qwen3.5 72B</td><td class="border border-gray-200 px-3 py-2 text-sm">Alibaba</td><td class="border border-gray-200 px-3 py-2 text-sm">8.6%</td><td class="border border-gray-200 px-3 py-2 text-sm">+1.4 pp</td><td class="border border-gray-200 px-3 py-2 text-sm">$0.40</td><td class="border border-gray-200 px-3 py-2 text-sm">$1.20</td></tr>
