<BaseLayout title={frontmatter.title} description={frontmatter.description} canonicalUrl={frontmatter.canonicalUrl}>
  <link rel="alternate" hreflang="en" href={frontmatter.url} />
  <link rel="alternate" hreflang="zh" href={frontmatter.zhUrl} />
