              <thead><tr class="bg-gray-100"><th class="px-3 py-2 text-left">Provider</th><th class="px-3 py-2 text-left">Free Tier</th><th class="px-3 py-2 text-left">Credit Card</th><th class="px-3 py-2 text-left">Best For</th></tr></thead>
