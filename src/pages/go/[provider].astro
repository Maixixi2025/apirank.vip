export function getStaticPaths() {
  return [
    { params: { provider: 'openai' }, props: { url: 'https://platform.openai.com', name: 'OpenAI' } },
    { params: { provider: 'anthropic' }, props: { url: 'https://console.anthropic.com', name: 'Anthropic' } },
    { params: { provider: 'deepseek' }, props: { url: 'https://platform.deepseek.com', name: 'DeepSeek' } },
    { params: { provider: 'google' }, props: { url: 'https://ai.google.dev', name: 'Google AI' } },
    { params: { provider: 'aliyun' }, props: { url: 'https://dashscope.console.aliyun.com', name: 'Alibaba Cloud' } },
    { params: { provider: 'baidu' }, props: { url: 'https://console.bce.baidu.com', name: 'Baidu' } },
    { params: { provider: 'tencent' }, props: { url: 'https://console.cloud.tencent.com', name: 'Tencent Cloud' } },
    { params: { provider: 'doubao' }, props: { url: 'https://console.volcengine.com/ark', name: 'Doubao' } },
    { params: { provider: 'zhipu' }, props: { url: 'https://open.bigmodel.cn', name: 'Zhipu AI' } },
    { params: { provider: 'moonshot' }, props: { url: 'https://platform.moonshot.cn', name: 'Moonshot AI' } },
