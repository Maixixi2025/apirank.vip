const sortedTutorials = tutorials.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<BaseLayout
  title="AI API 教程 - 入门指南 | APIRank"
  description="深度对比和评测，帮助你选择最合适的 AI API。DeepSeek vs OpenAI、API 价格指南等。"
>
  <div class="bg-gray-50 border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <nav class="flex items-center gap-2 text-sm text-gray-500">
        <a href="/zh" class="hover:text-blue-600">{t(locale, 'nav.home')}</a>
        <span>›</span>
        <span class="text-gray-900 font-medium">教程</span>
      </nav>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="text-center mb-12">
      <h1 class="text-3xl font-bold text-gray-900 mb-3">AI API 教程</h1>
      <p class="text-gray-600">深度评测与对比，帮助你选择最适合的 AI API</p>
    </div>

    <div class="space-y-6">
      {sortedTutorials.map((t) => (
        <a href={`/zh/tutorials/${t.slug}`} class="block bg-white rounded-xl border border-gray-200 p-6 hover:border-blue-300 hover:shadow-md transition-all">
          <div class="flex items-center gap-4 mb-3">
            <div class="text-3xl">{t.emoji}</div>
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-1">
                <span class="badge badge-primary text-xs">{t.tag}</span>
                <span class="text-xs text-gray-400">{t.date}</span>
                <span class="text-xs text-gray-400">•</span>
                <span class="text-xs text-gray-400">{t.readTime} 阅读</span>
              </div>
              <h2 class="text-lg font-bold text-gray-900">{t.title}</h2>
            </div>
          </div>
          <p class="text-gray-500 text-sm">{t.description}</p>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
