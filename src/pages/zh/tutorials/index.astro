    date: '2026-05-20',
    tag: 'API 测评',
    emoji: '🔮',
    readTime: '8 分钟',
  },
  {
    slug: 'tencent-hunyuan-api-review',
    title: '腾讯云 Hunyuan API 测评 2026：价格、模型与国内使用体验',
    description: '腾讯云 Hunyuan API 完整测评：Hunyuan Pro/Standard/Lite 价格详解、免费额度、微信生态整合，以及与 DeepSeek、OpenAI 在中国市场对比。',
    date: '2026-05-20',
    tag: 'API 测评',
    emoji: '⚙️',
    readTime: '8 分钟',
  },
  {
    slug: 'zhipu-glm-4-api-review',
    title: '智谱 AI GLM-4 API 测评 2026：价格、免费额度与国内使用体验',
    description: '完整测评智谱 AI GLM-4 API：定价策略、免费额度、模型能力、与 DeepSeek/OpenAI 的对比，中国开发者首选。',
    date: '2026-05-19',
    tag: 'API 测评',
    emoji: '🔬',
    readTime: '8 分钟',
  },
  {
    slug: 'moonshot-kimi-api-review',
    title: 'Moonshot AI (Kimi) API 完整测评 2026：价格、模型与国内使用体验',
    description: '月之暗面 Kimi API 完整测评：定价策略、128K 上下文、免费额度，与 DeepSeek、OpenAI 对比，中国开发者首选。',
    date: '2026-05-18',
    tag: 'API 测评',
    emoji: '🔬',
    readTime: '9 分钟',
  },
  {
    slug: 'aliyun-bailian-api-review',
    title: '阿里云百炼 API 测评：qwen 模型价格与体验',
    description: '完整指南：阿里云百炼 API — qwen 模型价格、免费额度与国内使用体验，2026-05-17 更新。',
    date: '2026-05-17',
    tag: 'API 测评',
    emoji: '⚙️',
    readTime: '9 分钟',
  },
  {
    slug: 'google-gemini-api-review',
    title: 'Google Gemini API 测评：免费额度与在中国使用',
    description: '对比 Google Gemini API 价格、免费额度限制、中国访问方式。找到最适合你项目的 Gemini 模型。',
    date: '2026-05-17',
    tag: 'API 测评',
    emoji: '🔬',
