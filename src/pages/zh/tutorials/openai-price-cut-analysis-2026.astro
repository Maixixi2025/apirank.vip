};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "OpenAI 真的会降价吗？还是只是传言？", "acceptedAnswer": { "@type": "Answer", "text": "截至 2026 年 6 月 12 日，官方尚未宣布。消息源自 Gary Marcus 的 Substack 文章引用匿名来源。OpenAI 历史上定期调整定价——GPT-4o mini 在 2025 年从 $0.15/$0.60 降至 $0.10/$0.40。" } },
    { "@type": "Question", "name": "我该现在切换厂商还是等降价？", "acceptedAnswer": { "@type": "Answer", "text": "生产应用不要等——用好当前性价比最好的厂商。长期来看，设计厂商无关的 API 层，让代码不受定价变动影响。一个 API Key 接入 DeepSeek、Qwen、Llama 的聚合器（如 FreeModel）是最低成本的方案。" } },
