             rel="sponsored noopener" target="_blank">
            {affiliateSidebar.cta}
          </a>
        </div>
        <div class="bg-gray-50 border border-gray-200 rounded-lg p-4">
          <h3 class="font-semibold text-gray-900 mb-2">速查</h3>
          <ul class="text-sm text-gray-700 space-y-1">
            <li><strong>平台:</strong> RunPod(GPU 云)</li>
            <li><strong>定价:</strong> $0.69/小时 RTX 4090 至 $7.39/小时 B300(按秒)</li>
            <li><strong>冷启动:</strong> FlashBoot 亚 200ms(Serverless)</li>
