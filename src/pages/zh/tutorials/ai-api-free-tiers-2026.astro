                <tr><td class="px-3 py-2 border-b"><strong>智谱 GLM-3-Turbo</strong></td><td class="px-3 py-2 border-b">无限免费调用</td><td class="px-3 py-2 border-b">不需要</td><td class="px-3 py-2 border-b">中文应用</td></tr>
                <tr><td class="px-3 py-2 border-b"><strong>OpenAI</strong></td><td class="px-3 py-2 border-b">$5 免费额度</td><td class="px-3 py-2 border-b">需要</td><td class="px-3 py-2 border-b">通用 LLM</td></tr>
                <tr><td class="px-3 py-2 border-b"><strong>DeepSeek</strong></td><td class="px-3 py-2 border-b">$2 免费额度</td><td class="px-3 py-2 border-b">不需要</td><td class="px-3 py-2 border-b">预算敏感</td></tr>
                <tr><td class="px-3 py-2 border-b"><strong>FreeModel</strong></td><td class="px-3 py-2 border-b">免费额度 + 国内直连</td><td class="px-3 py-2 border-b">不需要</td><td class="px-3 py-2 border-b">国内开发者</td></tr>
                <tr><td class="px-3 py-2 border-b"><strong>Fireworks AI</strong></td><td class="px-3 py-2 border-b">$5 免费额度</td><td class="px-3 py-2 border-b">不需要</td><td class="px-3 py-2 border-b">生产推理</td></tr>
