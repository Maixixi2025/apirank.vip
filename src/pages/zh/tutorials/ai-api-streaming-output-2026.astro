<tr class="bg-gray-50"><td class="border border-gray-300 px-4 py-2">DeepSeek</td><td class="border border-gray-300 px-4 py-2">OpenAI SSE</td><td class="border border-gray-300 px-4 py-2">支持</td><td class="border border-gray-300 px-4 py-2">完全兼容</td></tr>
<tr><td class="border border-gray-300 px-4 py-2">Groq</td><td class="border border-gray-300 px-4 py-2">OpenAI SSE</td><td class="border border-gray-300 px-4 py-2">支持</td><td class="border border-gray-300 px-4 py-2">完全兼容</td></tr>
<tr class="bg-gray-50"><td class="border border-gray-300 px-4 py-2">Cerebras</td><td class="border border-gray-300 px-4 py-2">OpenAI SSE</td><td class="border border-gray-300 px-4 py-2">支持</td><td class="border border-gray-300 px-4 py-2">完全兼容</td></tr>
<tr><td class="border border-gray-300 px-4 py-2">Together AI</td><td class="border border-gray-300 px-4 py-2">OpenAI SSE</td><td class="border border-gray-300 px-4 py-2">支持</td><td class="border border-gray-300 px-4 py-2">完全兼容</td></tr>
<tr class="bg-gray-50"><td class="border border-gray-300 px-4 py-2">Fireworks AI</td><td class="border border-gray-300 px-4 py-2">OpenAI SSE</td><td class="border border-gray-300 px-4 py-2">支持</td><td class="border border-gray-300 px-4 py-2">完全兼容</td></tr>
<tr><td class="border border-gray-300 px-4 py-2">xAI Grok</td><td class="border border-gray-300 px-4 py-2">OpenAI SSE</td><td class="border border-gray-300 px-4 py-2">支持</td><td class="border border-gray-300 px-4 py-2">完全兼容</td></tr>
<tr class="bg-gray-50"><td class="border border-gray-300 px-4 py-2">Mistral AI</td><td class="border border-gray-300 px-4 py-2">OpenAI SSE</td><td class="border border-gray-300 px-4 py-2">支持</td><td class="border border-gray-300 px-4 py-2">完全兼容</td></tr>
<tr><td class="border border-gray-300 px-4 py-2">Cohere</td><td class="border border-gray-300 px-4 py-2">自定义 SSE</td><td class="border border-gray-300 px-4 py-2">支持</td><td class="border border-gray-300 px-4 py-2">text 字段</td></tr>
<tr class="bg-gray-50"><td class="border border-gray-300 px-4 py-2">OpenRouter</td><td class="border border-gray-300 px-4 py-2">OpenAI SSE</td><td class="border border-gray-300 px-4 py-2">支持</td><td class="border border-gray-300 px-4 py-2">代理上游格式</td></tr>
</table>

<p class="text-sm text-gray-600 italic mb-6">核心发现：12 家厂商中有 9 家使用纯 OpenAI 兼容的 SSE 流式格式。如果你的代码已经适配 OpenAI 流式，只需改 base URL 和 API key 即可切换。</p>

