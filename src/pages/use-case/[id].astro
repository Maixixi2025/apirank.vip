---
import BaseLayout from '../../layouts/BaseLayout.astro';
import providers from '../../data/providers.json';
import useCases from '../../data/pseo/use-cases.json';

export function getStaticPaths() {
  return useCases.map(uc => ({
    params: { id: uc.id },
    props: { uc },
  }));
}

const { id } = Astro.params;
const { uc } = Astro.props;

const ucProviders = providers.filter(p => uc.providers.includes(p.id));
const sortedProviders = ucProviders.sort((a, b) => a.overallRank - b.overallRank);

// Best overall pick
const best = sortedProviders[0];
const budgetPick = sortedProviders.find(p => p.priceRank === 5) || sortedProviders[sortedProviders.length - 1];
const chinaPick = sortedProviders.find(p => p.category === 'domestic');

const title = `Best AI API for ${uc.label.en} — Provider Comparison 2026 | APIRank`;
const description = `Compare the best ${ucProviders.length} AI APIs for ${uc.label.en.toLowerCase()}: pricing, features, China access, and free tier. Updated 2026.`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": `${uc.label.en} — Best AI API Providers`,
  "description": description,
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://apirank.vip" },
    { "@type": "ListItem", "position": 2, "name": "Use Cases", "item": "https://apirank.vip/use-case" },
    { "@type": "ListItem", "position": 3, "name": uc.label.en, "item": `https://apirank.vip/use-case/${id}` }
  ]
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `What is the best AI API for ${uc.label.en.toLowerCase()}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `${best?.name} is our top pick for ${uc.label.en.toLowerCase()}, ranked #${best?.overallRank} overall with ${best?.pricing.input} input pricing.`
      }
    },
    {
      "@type": "Question",
      "name": `Which AI API is cheapest for ${uc.label.en.toLowerCase()}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `${budgetPick?.name} offers the lowest prices at ${budgetPick?.pricing.input} input.`
      }
    },
    {
      "@type": "Question",
      "name": `Which AI API works in China for ${uc.label.en.toLowerCase()}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `${chinaPick?.name} (${chinaPick?.availabilityEN}) is the best China-accessible option for ${uc.label.en.toLowerCase()}.`
      }
    }
  ]
};
---

<BaseLayout title={title} description={description} type="article">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <!-- Breadcrumb -->
  <div class="bg-gray-50 border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <nav class="flex items-center gap-2 text-sm text-gray-500">
        <a href="/" class="hover:text-blue-600">Home</a>
        <span>›</span>
        <a href="/use-case" class="hover:text-blue-600">Use Cases</a>
        <span>›</span>
        <span class="text-gray-900 font-medium">{uc.label.en}</span>
      </nav>
    </div>
  </div>

  <article class="py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

        <div class="lg:col-span-2 space-y-8">

          <header>
            <h1 class="text-3xl font-bold text-gray-900 mb-3">
              Best AI APIs for {uc.label.en}
            </h1>
            <p class="text-lg text-gray-600 mb-4">
              {sortedProviders.length} providers compared for {uc.label.en.toLowerCase()}. Updated {new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}.
            </p>
            <div class="flex flex-wrap gap-3">
              <a href={`/compare/${best?.id}-vs-${sortedProviders[1]?.id}`} class="inline-flex items-center gap-2 bg-blue-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-blue-700 transition-colors">
                ⚔️ {best?.name} vs {sortedProviders[1]?.name}
              </a>
              <a href={`/providers/${best?.id}`} class="inline-flex items-center gap-2 bg-gray-100 text-gray-700 px-4 py-2 rounded-lg text-sm font-medium hover:bg-gray-200 transition-colors">
                📖 {best?.name} Details →
              </a>
            </div>
          </header>

          <div class="adsense-placeholder h-24 rounded-lg"></div>

          <!-- Quick Picks -->
          <section class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div class="bg-green-50 border border-green-100 rounded-xl p-4">
              <div class="text-xs text-green-600 font-semibold uppercase tracking-wide mb-1">🏆 Top Pick</div>
              <div class="font-bold text-gray-900">{best?.name}</div>
              <div class="text-sm text-gray-500 mt-1">{best?.availabilityEN}</div>
            </div>
            <div class="bg-yellow-50 border border-yellow-100 rounded-xl p-4">
              <div class="text-xs text-yellow-600 font-semibold uppercase tracking-wide mb-1">💰 Budget Pick</div>
              <div class="font-bold text-gray-900">{budgetPick?.name}</div>
              <div class="text-sm text-gray-500 mt-1">{budgetPick?.pricing.input} input</div>
            </div>
            <div class="bg-blue-50 border border-blue-100 rounded-xl p-4">
              <div class="text-xs text-blue-600 font-semibold uppercase tracking-wide mb-1">🇨🇳 China Pick</div>
              <div class="font-bold text-gray-900">{chinaPick?.name}</div>
              <div class="text-sm text-gray-500 mt-1">{chinaPick?.availabilityEN}</div>
            </div>
          </section>

          <!-- Provider Comparison Table -->
          <section class="bg-white rounded-xl border border-gray-200 p-6">
            <h2 class="text-xl font-bold text-gray-900 mb-4">📊 {uc.label.en} — Provider Comparison</h2>
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-gray-100">
                  <th class="text-left py-3 font-semibold text-gray-500">Provider</th>
                  <th class="text-center py-3 font-semibold text-gray-500">Input</th>
                  <th class="text-center py-3 font-semibold text-gray-500">Output</th>
                  <th class="text-center py-3 font-semibold text-gray-500">China Access</th>
                  <th class="text-center py-3 font-semibold text-gray-500">Free Tier</th>
                  <th class="text-center py-3 font-semibold text-gray-500">Rank</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-50">
                {sortedProviders.map((p, i) => (
                  <tr class={i === 0 ? 'bg-green-50' : ''}>
                    <td class="py-3">
                      <a href={`/providers/${p.id}`} class="font-semibold text-gray-900 hover:text-blue-600">
                        {p.name}
                      </a>
                    </td>
                    <td class="py-3 text-center font-mono text-blue-600 text-xs">{p.pricing.input}</td>
                    <td class="py-3 text-center font-mono text-green-600 text-xs">{p.pricing.output}</td>
                    <td class={`py-3 text-center text-xs font-semibold ${p.availabilityEN.includes('✅') ? 'text-green-600' : p.availabilityEN.includes('⚠️') ? 'text-yellow-600' : 'text-red-500'}`}>{p.availabilityEN.split(' ')[0]}</td>
                    <td class="py-3 text-center text-xs text-gray-600">{p.freeTierEN.split('(')[0].trim()}</td>
                    <td class="py-3 text-center font-bold text-blue-600">#{p.overallRank}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </section>

          <!-- Top Provider Detail -->
          <section class="bg-white rounded-xl border border-gray-200 p-6">
            <h2 class="text-xl font-bold text-gray-900 mb-4">🏆 Best Choice: {best?.name}</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <h3 class="font-semibold text-green-700 mb-2">✨ Pros</h3>
                <ul class="space-y-1.5">
                  {(best?.highlightsEN || best?.highlights).map(h => (
                    <li class="flex items-start gap-2 text-sm text-gray-700">
                      <span class="text-green-500 mt-0.5">✓</span><span>{h}</span>
                    </li>
                  ))}
                </ul>
              </div>
              <div>
                <h3 class="font-semibold text-red-700 mb-2">⚠️ Cons</h3>
                <ul class="space-y-1.5">
                  {(best?.consEN || best?.cons).map(c => (
                    <li class="flex items-start gap-2 text-sm text-gray-700">
                      <span class="text-red-400 mt-0.5">×</span><span>{c}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
            <div class="mt-4 p-4 bg-gray-50 rounded-lg">
              <p class="text-sm text-gray-600"><span class="font-semibold">🎯 Best for:</span> {best?.bestForEN || best?.bestFor}</p>
            </div>
          </section>

          <div class="adsense-placeholder h-24 rounded-lg"></div>

          <!-- FAQ -->
          <section class="bg-white rounded-xl border border-gray-200 p-6">
            <h2 class="text-xl font-bold text-gray-900 mb-4">❓ FAQ</h2>
            <div class="space-y-4">
              <details class="group" open>
                <summary class="font-semibold text-gray-800 cursor-pointer list-none flex items-center justify-between">
                  What is the best AI API for {uc.label.en.toLowerCase()}?
                  <span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
                </summary>
                <p class="text-gray-600 mt-2 text-sm">
                  {best?.name} is our top pick. Ranked #{best?.overallRank} overall with {best?.pricing.input} input pricing, {best?.availabilityEN}.
                </p>
              </details>
              <div class="border-t border-gray-100"></div>
              <details class="group">
                <summary class="font-semibold text-gray-800 cursor-pointer list-none flex items-center justify-between">
                  Which is the cheapest for {uc.label.en.toLowerCase()}?
                  <span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
                </summary>
                <p class="text-gray-600 mt-2 text-sm">
                  {budgetPick?.name} offers the lowest prices at {budgetPick?.pricing.input} input — ideal for cost-sensitive {uc.label.en.toLowerCase()} projects.
                </p>
              </details>
              <div class="border-t border-gray-100"></div>
              <details class="group">
                <summary class="font-semibold text-gray-800 cursor-pointer list-none flex items-center justify-between">
                  Which providers support China access for {uc.label.en.toLowerCase()}?
                  <span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
                </summary>
                <p class="text-gray-600 mt-2 text-sm">
                  {ucProviders.filter(p => p.category === 'domestic').map(p => p.name).join(', ')} are the best options with direct China access.
                </p>
              </details>
            </div>
          </section>

          <!-- Related Use Cases -->
          <section class="bg-gray-50 rounded-xl border border-gray-200 p-6">
            <h2 class="text-lg font-bold text-gray-900 mb-4">🔗 Related Use Cases</h2>
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
              {useCases.filter(u => u.id !== id).slice(0, 4).map(u => (
                <a href={`/use-case/${u.id}`} class="block bg-white rounded-lg border border-gray-200 p-3 text-center hover:border-blue-300 hover:shadow-sm transition-all">
                  <span class="text-sm font-medium text-gray-800">{u.label.en}</span>
                </a>
              ))}
            </div>
          </section>

        </div>

        <!-- Sidebar -->
        <aside class="space-y-6">
          <div class="bg-white rounded-xl border border-gray-200 p-6 sticky top-20">
            <h3 class="font-bold text-gray-900 mb-3">Get Started</h3>
            <div class="space-y-3">
              <a href={`/providers/${best?.id}`} class="btn-primary w-full text-center block">View {best?.name} →</a>
              <a href="/providers" class="block text-center text-blue-600 text-sm font-medium py-2 hover:underline">All Providers →</a>
            </div>
          </div>

          <div class="bg-white rounded-xl border border-gray-200 p-6">
            <h3 class="font-bold text-gray-900 mb-4">🏆 All Providers</h3>
            <div class="space-y-2">
              {providers.sort((a, b) => a.overallRank - b.overallRank).map(p => (
                <a href={`/providers/${p.id}`} class="flex items-center justify-between py-1.5 text-sm hover:text-blue-600 transition-colors">
                  <span>{p.name}</span>
                  <span class="text-gray-400 text-xs">#{p.overallRank}</span>
                </a>
              ))}
            </div>
          </div>

          <div class="bg-white rounded-xl border border-gray-200 p-6">
            <h3 class="font-bold text-gray-900 mb-4">⚡ Quick Stats</h3>
            <div class="space-y-3 text-sm">
              <div class="flex justify-between"><span class="text-gray-500">Providers</span><span class="font-semibold">{sortedProviders.length}</span></div>
              <div class="flex justify-between"><span class="text-gray-500">Use Cases</span><span class="font-semibold">{useCases.length}</span></div>
            </div>
          </div>
        </aside>

      </div>
    </div>
  </article>
</BaseLayout>