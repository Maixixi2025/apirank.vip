---
import BaseLayout from '../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

// Read pre-built tutorials list (generated by build script in seo-assets/scripts/)
// Falls back to parsing tutorial files at build time if missing.
const tutorialsPath = path.join(process.cwd(), 'src/data/tutorials.json');
let tutorials: Array<{slug: string; date: string; enTitle: string; enDescription: string; category: string}> = [];

if (fs.existsSync(tutorialsPath)) {
  tutorials = JSON.parse(fs.readFileSync(tutorialsPath, 'utf-8'));
} else {
  // Fallback: parse all tutorial .astro files (limited data, but works)
  const modules = import.meta.glob('./tutorials/*.astro', { eager: true });
  for (const [path, mod] of Object.entries(modules)) {
    const slug = path.replace('./tutorials/', '').replace('.astro', '');
    const date = (mod as any).date || '';
    const enTitle = (mod as any).enTitle || slug;
    const enDescription = (mod as any).enDescription || '';
    const category = (mod as any).category || 'Review';
    if (date) {
      tutorials.push({ slug, date, enTitle, enDescription, category });
    }
  }
  tutorials.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
}

const topTutorials = tutorials.slice(0, 12);
---

<BaseLayout
  title="AI API Tutorials & Reviews 2026 | APIRank Blog"
  description="In-depth AI API reviews, pricing comparisons, and tutorials. Updated weekly for OpenAI, Anthropic, DeepSeek, Google Gemini, and 15+ providers."
  canonicalUrl="https://apirank.vip/blog/"
>
  <div class="bg-gray-50 border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <nav class="flex items-center gap-2 text-sm text-gray-500">
        <a href="/" class="hover:text-blue-600">Home</a>
        <span>›</span>
        <span class="text-gray-900 font-medium">Blog</span>
      </nav>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <header class="mb-12">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">APIRank Blog</h1>
      <p class="text-lg text-gray-600 max-w-3xl">
        Independent AI API reviews, pricing comparisons, and developer tutorials.
        Updated weekly. We track 15+ providers including OpenAI, Anthropic, DeepSeek, Google Gemini, and Chinese options.
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {topTutorials.map(t => (
        <article class="bg-white rounded-xl border border-gray-200 hover:border-blue-500 transition-colors overflow-hidden flex flex-col">
          <a href={`/tutorials/${t.slug}`} class="block p-6 flex-1 flex flex-col">
            <div class="flex items-center gap-2 mb-3">
              <span class="text-xs font-medium text-blue-600 bg-blue-50 px-2 py-1 rounded">
                {t.category}
              </span>
              <time class="text-xs text-gray-500" datetime={t.date}>
                {new Date(t.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </time>
            </div>
            <h2 class="text-lg font-bold text-gray-900 mb-2 leading-tight">
              {t.enTitle}
            </h2>
            <p class="text-sm text-gray-600 mb-4 flex-1 line-clamp-3">
              {t.enDescription}
            </p>
            <span class="text-sm font-medium text-blue-600 hover:text-blue-700">
              Read review →
            </span>
          </a>
        </article>
      ))}
    </div>

    <div class="mt-12 text-center">
      <a href="/tutorials" class="inline-block bg-blue-600 text-white font-medium px-6 py-3 rounded-lg hover:bg-blue-700 transition-colors">
        View All Tutorials →
      </a>
    </div>
  </div>
</BaseLayout>
