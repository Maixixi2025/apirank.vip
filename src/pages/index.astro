---
import BaseLayout from '../layouts/BaseLayout.astro';
import providers from '../data/providers.json';

const locale = 'en';

// Sort by overall rank
const sortedProviders = [...providers].sort((a, b) => a.overallRank - b.overallRank);
const domesticProviders = sortedProviders.filter(p => p.category === 'domestic');
const intlProviders = sortedProviders.filter(p => p.category === 'international');
const aggregatorProviders = sortedProviders.filter(p => p.category === 'aggregator');

// JSON-LD: FAQPage for homepage
const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Which AI API is cheapest for Chinese developers?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "DeepSeek offers the lowest prices at ¥1/1M tokens input, directly accessible from mainland China without a proxy. Google AI's Gemini 2.5 Flash is also very competitive at $0.016/1M."
      }
    },
    {
      "@type": "Question",
      "name": "Can I use OpenAI's API in China?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "OpenAI's API is blocked in mainland China. You need a proxy or VPN service to access it, which adds complexity and reliability concerns."
      }
    },
    {
      "@type": "Question",
      "name": "Which AI API has the best free tier?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Google AI (Gemini 2.0 Flash) offers unlimited free usage. DeepSeek gives $2 signup bonus, and OpenAI offers $5 free credit for new users."
      }
    }
  ]
};
---

<BaseLayout
  title="AI API Token Price Comparison & In-Depth Reviews | APIRank"
  description="Compare real-time pricing from 10+ top AI providers including OpenAI, Claude, DeepSeek, Gemini, and more. Always up to date, completely free."
>
  <!-- JSON-LD FAQ -->
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-blue-50 via-white to-indigo-50 py-16 sm:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto">
        <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 mb-6 leading-tight">
          Find the Most <span class="text-blue-600">Cost-Effective</span> AI Token Plan
        </h1>
        <p class="text-lg sm:text-xl text-gray-600 mb-8 leading-relaxed">
          Compare real-time pricing from 10+ top AI providers including OpenAI, Claude, DeepSeek, Gemini, and more. Always up to date, completely free.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="#providers" class="btn-primary text-lg py-3 px-8">View Price Comparison →</a>
          <a href="/tutorials" class="btn-secondary text-lg py-3 px-8">Getting Started →</a>
        </div>
      </div>

      <!-- Quick Stats -->
      <div class="mt-12 grid grid-cols-3 gap-4 sm:gap-8 max-w-2xl mx-auto text-center">
        <div>
          <div class="text-3xl sm:text-4xl font-bold text-blue-600">10+</div>
          <div class="text-sm text-gray-500 mt-1">Providers</div>
        </div>
        <div>
          <div class="text-3xl sm:text-4xl font-bold text-green-600">50+</div>
          <div class="text-sm text-gray-500 mt-1">Models</div>
        </div>
        <div>
          <div class="text-3xl sm:text-4xl font-bold text-indigo-600">Real-time</div>
          <div class="text-sm text-gray-500 mt-1">Updates</div>
        </div>
      </div>
    </div>
  </section>

  <!-- AdSense Position 1: After Hero -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <div class="adsense-placeholder h-28 rounded-lg"></div>
  </section>

  <!-- Domestic Providers Section -->
  <section id="providers" class="py-12 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-3 mb-8">
        <span class="text-2xl">🇨🇳</span>
        <h2 class="text-2xl font-bold text-gray-900">AI APIs Available in China</h2>
        <span class="badge badge-success text-xs">Direct Access</span>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
        {domesticProviders.map((provider) => (
          <a href={`/providers/${provider.id}`} class="provider-card group">
            <div class="flex items-center justify-between">
              <h3 class="font-bold text-gray-900 group-hover:text-blue-600 transition-colors">
                {provider.name}
              </h3>
              <span class={`badge text-xs ${provider.overallRank <= 3 ? 'badge-success' : 'bg-gray-100 text-gray-600'}`}>
                #{provider.overallRank}
              </span>
            </div>
            <p class="text-sm text-gray-500">{provider.name}</p>
            <div class="mt-3 space-y-1 text-sm">
              <div class="flex justify-between">
                <span class="text-gray-500">Input</span>
                <span class="font-medium text-gray-900">{provider.pricing.input}</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-500">Output</span>
                <span class="font-medium text-gray-900">{provider.pricing.output}</span>
              </div>
            </div>
            <div class="mt-3 pt-3 border-t border-gray-100">
              <div class="flex items-center gap-2">
                <span class="text-green-600 text-xs font-medium">{provider.availabilityEN}</span>
                <span class="flex-1"></span>
                <span class="text-xs text-gray-400">Free Tier</span>
              </div>
              <p class="text-xs text-gray-500 mt-1">{provider.freeTierEN}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- International Providers Section -->
  <section class="py-12 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-3 mb-8">
        <span class="text-2xl">🌍</span>
        <h2 class="text-2xl font-bold text-gray-900">International AI APIs</h2>
        <span class="badge badge-warning text-xs">Proxy Required</span>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
        {intlProviders.map((provider) => (
          <a href={`/providers/${provider.id}`} class="provider-card group">
            <div class="flex items-center justify-between">
              <h3 class="font-bold text-gray-900 group-hover:text-blue-600 transition-colors">
                {provider.name}
              </h3>
              <span class="badge bg-blue-100 text-blue-700 text-xs">
                #{provider.overallRank}
              </span>
            </div>
            <p class="text-sm text-gray-500">{provider.name}</p>
            <div class="mt-3 space-y-1 text-sm">
              <div class="flex justify-between">
                <span class="text-gray-500">Input</span>
                <span class="font-medium text-gray-900">{provider.pricing.input}</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-500">Output</span>
                <span class="font-medium text-gray-900">{provider.pricing.output}</span>
              </div>
            </div>
            <div class="mt-3 pt-3 border-t border-gray-100">
              <div class="flex items-center gap-2">
                <span class={`text-xs font-medium ${provider.availabilityEN.includes('❌') ? 'text-red-500' : 'text-yellow-500'}`}>
                  {provider.availabilityEN}
                </span>
                <span class="flex-1"></span>
                <span class="text-xs text-gray-400">Free Tier</span>
              </div>
              <p class="text-xs text-gray-500 mt-1">{provider.freeTierEN}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- AdSense Position 2: After Provider Grid -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <div class="adsense-placeholder h-28 rounded-lg"></div>
  </section>

  <!-- AI API Gateways & Aggregators Section -->
  <section class="py-12 bg-indigo-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-3 mb-2">
        <span class="text-2xl">🔗</span>
        <h2 class="text-2xl font-bold text-gray-900">AI API Gateways & Aggregators</h2>
      </div>
      <p class="text-gray-500 text-sm mb-8">One API key → 400+ models. Unified access with auto-routing and model flexibility.</p>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
        {aggregatorProviders.map((provider) => (
          <a href={`/providers/${provider.id}`} class="provider-card group bg-white border-indigo-100 hover:border-indigo-300">
            <div class="flex items-center justify-between">
              <h3 class="font-bold text-gray-900 group-hover:text-indigo-600 transition-colors">
                {provider.name}
              </h3>
              <span class="badge bg-indigo-100 text-indigo-700 text-xs">
                #{provider.overallRank}
              </span>
            </div>
            <p class="text-sm text-gray-500 mt-1">{provider.modelCount}+ models</p>
            <div class="mt-3 space-y-1 text-sm">
              <div class="flex justify-between">
                <span class="text-gray-500">Top Feature</span>
              </div>
              <p class="text-gray-700 text-xs">{provider.highlightsEN?.[0] || provider.highlights[0]}</p>
            </div>
            <div class="mt-3 pt-3 border-t border-gray-100">
              <div class="flex items-center gap-2">
                <span class="text-xs font-medium text-indigo-600">{provider.availabilityEN}</span>
                <span class="flex-1"></span>
                <span class="text-xs text-gray-400">Free</span>
              </div>
              <p class="text-xs text-gray-500 mt-1">{provider.freeTierEN}</p>
            </div>
          </a>
        ))}
      </div>

      <div class="mt-6 text-center">
        <a href="/tutorials/openrouter-review" class="inline-flex items-center gap-2 text-indigo-600 hover:text-indigo-800 text-sm font-medium">
          OpenRouter Review: Is the aggregators worth it? →
        </a>
      </div>
    </div>
  </section>

  <!-- Price Comparison Table -->
  <section class="py-12 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">💰 Token Price Comparison</h2>

      <div class="overflow-x-auto">
        <table class="table-token">
          <thead>
            <tr>
              <th>Provider</th>
              <th>Popular Models</th>
              <th>Input</th>
              <th>Output</th>
              <th>China Available</th>
              <th>Free Tier</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            {sortedProviders.map((p) => (
              <tr>
                <td class="font-semibold text-gray-900">{p.name}</td>
                <td class="text-gray-600">{p.models.slice(0, 2).join(', ')}</td>
                <td class="font-mono text-sm">{p.pricing.input}</td>
                <td class="font-mono text-sm">{p.pricing.output}</td>
                <td>
                  <span class={`badge text-xs ${p.availabilityEN.includes('✅') ? 'badge-success' : p.availabilityEN.includes('⚠️') ? 'badge-warning' : 'badge-danger'}`}>
                    {p.availabilityEN}
                  </span>
                </td>
                <td class="text-xs text-gray-500">{p.freeTierEN}</td>
                <td>
                  <a href={`/providers/${p.id}`} class="text-blue-600 hover:text-blue-800 text-sm font-medium">
                    View Details →
                  </a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-12 bg-gray-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-8 text-center">Frequently Asked Questions</h2>

      <div class="space-y-6">
        <details class="bg-white rounded-lg border border-gray-200 p-5 group">
          <summary class="font-semibold text-gray-900 cursor-pointer list-none flex justify-between items-center">
            Which AI API is cheapest for Chinese developers?
            <span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="mt-3 text-gray-600 leading-relaxed">DeepSeek offers the lowest prices at ¥1/1M tokens input, directly accessible from mainland China without a proxy. Google AI's Gemini 2.5 Flash is also very competitive at $0.016/1M.</p>
        </details>

        <details class="bg-white rounded-lg border border-gray-200 p-5 group">
          <summary class="font-semibold text-gray-900 cursor-pointer list-none flex justify-between items-center">
            Can I use OpenAI's API in China?
            <span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="mt-3 text-gray-600 leading-relaxed">OpenAI's API is blocked in mainland China. You need a proxy or VPN service to access it, which adds complexity and reliability concerns.</p>
        </details>

        <details class="bg-white rounded-lg border border-gray-200 p-5 group">
          <summary class="font-semibold text-gray-900 cursor-pointer list-none flex justify-between items-center">
            Which AI API has the best free tier?
            <span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="mt-3 text-gray-600 leading-relaxed">Google AI (Gemini 2.0 Flash) offers unlimited free usage. DeepSeek gives $2 signup bonus, and OpenAI offers $5 free credit for new users.</p>
        </details>

        <details class="bg-white rounded-lg border border-gray-200 p-5 group">
          <summary class="font-semibold text-gray-900 cursor-pointer list-none flex justify-between items-center">
            What is the best AI API for production applications in China?
            <span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="mt-3 text-gray-600 leading-relaxed">For domestic China applications, DeepSeek is the top choice due to direct access, low pricing, and competitive model quality. For international products, OpenAI or Google AI offer more mature ecosystems.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 bg-blue-600">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold text-white mb-4">
        Ready to find the best AI API?
      </h2>
      <p class="text-blue-100 mb-8">
        Compare all major AI providers side-by-side with real-time pricing data.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="#providers" class="bg-white text-blue-600 font-semibold py-3 px-8 rounded-lg hover:bg-blue-50 transition-colors">
          View All Providers →
        </a>
        <a href="/tutorials" class="bg-blue-700 text-white font-semibold py-3 px-8 rounded-lg hover:bg-blue-800 transition-colors">
          Read Tutorials →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
