---
import BaseLayout from '../layouts/BaseLayout.astro';
import providers from '../data/providers.json';

// Sort by overall rank
const sortedProviders = [...providers].sort((a, b) => a.overallRank - b.overallRank);
const domesticProviders = sortedProviders.filter(p => p.category === 'domestic');
const intlProviders = sortedProviders.filter(p => p.category === 'international');

// JSON-LD: FAQPage for homepage
const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "哪个 AI API 最便宜？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "按单位性能比，DeepSeek-V3 和智谱 GLM-4 性价比最高。豆包价格最低但模型能力有限。建议根据具体任务选择。"
      }
    },
    {
      "@type": "Question",
      "name": "国内可以直连的 AI API 有哪些？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "DeepSeek、阿里云通义、百度文心、腾讯混元、字节豆包、智谱 GLM、月之暗面 Kimi 都支持国内直连，无需代理。"
      }
    },
    {
      "@type": "Question",
      "name": "如何申请 OpenAI API？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "访问 platform.openai.com 注册账号，充值后即可使用。需要代理访问，国内用户需要 VPN 或代理服务。"
      }
    }
  ]
};
---

<BaseLayout
  title="AI API Token 价格对比与深度测评 | APIRank"
  description="APIRank：最全面的 AI API Token 价格对比网站。收录 OpenAI、Anthropic、DeepSeek、Google Gemini、阿里通义、百度文心等主流 AI 厂商的最新价格、免费额度、国内可用性，帮你找到最划算的 AI API 方案。"
>
  <!-- JSON-LD FAQ -->
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-blue-50 via-white to-indigo-50 py-16 sm:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto">
        <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 mb-6 leading-tight">
          找到最划算的
          <span class="text-blue-600">AI Token</span>
          方案
        </h1>
        <p class="text-lg sm:text-xl text-gray-600 mb-8 leading-relaxed">
          收录 OpenAI、Claude、DeepSeek、Gemini 等
          <strong>10+ 主流 AI 厂商</strong>的最新 API 价格，
          实时更新，免费对比，帮你省钱。
        </p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="#providers" class="btn-primary text-lg py-3 px-8">
            查看价格对比 →
          </a>
          <a href="/tutorials" class="btn-secondary text-lg py-3 px-8">
            新手教程
          </a>
        </div>
      </div>
      
      <!-- Quick Stats -->
      <div class="mt-12 grid grid-cols-3 gap-4 sm:gap-8 max-w-2xl mx-auto text-center">
        <div>
          <div class="text-3xl sm:text-4xl font-bold text-blue-600">10+</div>
          <div class="text-sm text-gray-500 mt-1">收录厂商</div>
        </div>
        <div>
          <div class="text-3xl sm:text-4xl font-bold text-green-600">50+</div>
          <div class="text-sm text-gray-500 mt-1">覆盖模型</div>
        </div>
        <div>
          <div class="text-3xl sm:text-4xl font-bold text-indigo-600">实时</div>
          <div class="text-sm text-gray-500 mt-1">价格更新</div>
        </div>
      </div>
    </div>
  </section>

  <!-- AdSense Position 1: After Hero -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <div class="adsense-placeholder h-28 rounded-lg"></div>
  </section>

  <!-- Domestic Providers Section -->
  <section id="providers" class="py-12 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-3 mb-8">
        <span class="text-2xl">🇨🇳</span>
        <h2 class="text-2xl font-bold text-gray-900">国内可用 AI API</h2>
        <span class="badge badge-success text-xs">国内直连</span>
      </div>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
        {domesticProviders.map((provider) => (
          <a href={`/providers/${provider.id}`} class="provider-card group">
            <div class="flex items-center justify-between">
              <h3 class="font-bold text-gray-900 group-hover:text-blue-600 transition-colors">
                {provider.nameCn}
              </h3>
              <span class={`badge text-xs ${provider.overallRank <= 3 ? 'badge-success' : 'bg-gray-100 text-gray-600'}`}>
                #{provider.overallRank}
              </span>
            </div>
            <p class="text-sm text-gray-500">{provider.name}</p>
            <div class="mt-3 space-y-1 text-sm">
              <div class="flex justify-between">
                <span class="text-gray-500">输入</span>
                <span class="font-medium text-gray-900">{provider.pricing.input}</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-500">输出</span>
                <span class="font-medium text-gray-900">{provider.pricing.output}</span>
              </div>
            </div>
            <div class="mt-3 pt-3 border-t border-gray-100">
              <div class="flex items-center gap-2">
                <span class="text-green-600 text-xs font-medium">{provider.availabilityCN}</span>
                <span class="flex-1"></span>
                <span class="text-xs text-gray-400">免费额度</span>
              </div>
              <p class="text-xs text-gray-500 mt-1">{provider.freeTier}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- International Providers Section -->
  <section class="py-12 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-3 mb-8">
        <span class="text-2xl">🌍</span>
        <h2 class="text-2xl font-bold text-gray-900">国际 AI API</h2>
        <span class="badge badge-warning text-xs">需代理</span>
      </div>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
        {intlProviders.map((provider) => (
          <a href={`/providers/${provider.id}`} class="provider-card group">
            <div class="flex items-center justify-between">
              <h3 class="font-bold text-gray-900 group-hover:text-blue-600 transition-colors">
                {provider.nameCn}
              </h3>
              <span class="badge bg-blue-100 text-blue-700 text-xs">
                #{provider.overallRank}
              </span>
            </div>
            <p class="text-sm text-gray-500">{provider.name}</p>
            <div class="mt-3 space-y-1 text-sm">
              <div class="flex justify-between">
                <span class="text-gray-500">输入</span>
                <span class="font-medium text-gray-900">{provider.pricing.input}</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-500">输出</span>
                <span class="font-medium text-gray-900">{provider.pricing.output}</span>
              </div>
            </div>
            <div class="mt-3 pt-3 border-t border-gray-100">
              <div class="flex items-center gap-2">
                <span class={`text-xs font-medium ${provider.availabilityCN.includes('❌') ? 'text-red-500' : 'text-yellow-500'}`}>
                  {provider.availabilityCN}
                </span>
                <span class="flex-1"></span>
                <span class="text-xs text-gray-400">免费额度</span>
              </div>
              <p class="text-xs text-gray-500 mt-1">{provider.freeTier}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- AdSense Position 2: After Provider Grid -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <div class="adsense-placeholder h-28 rounded-lg"></div>
  </section>

  <!-- Price Comparison Table -->
  <section class="py-12 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">💰 Token 价格对比表</h2>
      
      <div class="overflow-x-auto">
        <table class="table-token">
          <thead>
            <tr>
              <th>厂商</th>
              <th>热门模型</th>
              <th>输入价格</th>
              <th>输出价格</th>
              <th>国内可用</th>
              <th>综合评分</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            {sortedProviders.map((p) => (
              <tr>
                <td class="font-semibold text-gray-900">{p.nameCn}</td>
                <td class="text-gray-600">{p.models.slice(0, 2).join(', ')}</td>
                <td class="font-mono text-sm">{p.pricing.input}</td>
                <td class="font-mono text-sm">{p.pricing.output}</td>
                <td>
                  <span class={`badge text-xs ${p.availabilityCN.includes('✅') ? 'badge-success' : p.availabilityCN.includes('⚠️') ? 'badge-warning' : 'badge-danger'}`}>
                    {p.availabilityCN}
                  </span>
                </td>
                <td>
                  <div class="flex items-center gap-1">
                    <span class="text-yellow-500">★</span>
                    <span class="font-semibold">{p.overallRank <= 3 ? '⭐⭐⭐' : p.overallRank <= 6 ? '⭐⭐' : '⭐'}</span>
                  </div>
                </td>
                <td>
                  <a href={`/providers/${p.id}`} class="text-blue-600 hover:text-blue-800 text-sm font-medium">
                    查看详情 →
                  </a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-12 bg-gray-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-8 text-center">❓ 常见问题</h2>
      
      <div class="space-y-6">
        <details class="bg-white rounded-lg border border-gray-200 p-5 group">
          <summary class="font-semibold text-gray-900 cursor-pointer list-none flex justify-between items-center">
            哪个 AI API 最便宜？
            <span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="mt-3 text-gray-600 leading-relaxed">
            按绝对价格，<strong>字节豆包</strong>和<strong>DeepSeek-V3</strong>最便宜。但要综合考虑模型能力，
            <strong>DeepSeek</strong>在性价比上最强，是目前最推荐的低价高能方案。
          </p>
        </details>
        
        <details class="bg-white rounded-lg border border-gray-200 p-5 group">
          <summary class="font-semibold text-gray-900 cursor-pointer list-none flex justify-between items-center">
            国内可以用 OpenAI 和 Claude API 吗？
            <span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="mt-3 text-gray-600 leading-relaxed">
            理论上可以，但需要<strong>代理服务</strong>。国内直连会被限制或速度极慢。
            建议使用国内可直连的方案（如 DeepSeek、智谱GLM），或使用
            <a href="/providers/openai" class="text-blue-600 underline">API 反代服务</a>。
          </p>
        </details>
        
        <details class="bg-white rounded-lg border border-gray-200 p-5 group">
          <summary class="font-semibold text-gray-900 cursor-pointer list-none flex justify-between items-center">
            DeepSeek API 真的能用吗？质量如何？
            <span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="mt-3 text-gray-600 leading-relaxed">
            <strong>DeepSeek-V3</strong>和<strong>DeepSeek-R1</strong>已经达到 GPT-4 级别，
            在编程和数学推理上甚至更强。DeepSeek-R1 支持思维链输出，推理过程透明。
            唯一缺点是生态不如 OpenAI 丰富，但价格是 OpenAI 的几十分之一。
          </p>
        </details>
        
        <details class="bg-white rounded-lg border border-gray-200 p-5 group">
          <summary class="font-semibold text-gray-900 cursor-pointer list-none flex justify-between items-center">
            如何申请这些 AI API？
            <span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="mt-3 text-gray-600 leading-relaxed">
            每个厂商流程类似：注册账号 → 实名认证（国内平台）→ 充值/购买资源包 → 获取 API Key → 开始调用。
            具体教程请查看我们的<a href="/tutorials" class="text-blue-600 underline">使用教程</a>页面。
          </p>
        </details>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 bg-blue-600">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold text-white mb-4">
        准备好开始使用了吗？
      </h2>
      <p class="text-blue-100 mb-8">
        立即对比各平台价格，选择最适合你的 AI 方案
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="#providers" class="bg-white text-blue-600 font-semibold py-3 px-8 rounded-lg hover:bg-blue-50 transition-colors">
          查看价格对比
        </a>
        <a href="/tutorials" class="bg-blue-700 text-white font-semibold py-3 px-8 rounded-lg hover:bg-blue-800 transition-colors">
          新手教程
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
