---
import BaseLayout from '../layouts/BaseLayout.astro';
import providers from '../data/providers.json';
import { t } from '../i18n/utils';

const locale = 'en';

const sortedProviders = [...providers].sort((a, b) => a.overallRank - b.overallRank);
const domesticProviders = sortedProviders.filter(p => p.category === 'domestic');
const intlProviders = sortedProviders.filter(p => p.category === 'international');

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Which AI API is the cheapest?",
      "acceptedAnswer": { "@type": "Answer", "text": "By absolute price, Doubao and DeepSeek-V3 are the cheapest. But considering model capability, DeepSeek offers the best value — currently the most recommended low-cost high-performance option." }
    },
    {
      "@type": "Question",
      "name": "Can I use OpenAI and Claude API in China?",
      "acceptedAnswer": { "@type": "Answer", "text": "In theory yes, but a proxy service is required. Direct access from China is restricted or extremely slow. We recommend using domestic direct-access options (like DeepSeek, Zhipu GLM) or an API proxy service." }
    },
    {
      "@type": "Question",
      "name": "Is DeepSeek API actually usable? How is the quality?",
      "acceptedAnswer": { "@type": "Answer", "text": "DeepSeek-V3 and DeepSeek-R1 have reached GPT-4 level capability, even stronger in coding and math reasoning. DeepSeek-R1 supports chain-of-thought output with transparent reasoning." }
    }
  ]
};
---

<BaseLayout
  title="AI API Token Price Comparison & In-Depth Reviews | APIRank"
  description="APIRank: The most comprehensive AI API token price comparison site. Compare latest pricing, free tiers, and China accessibility for OpenAI, Anthropic, DeepSeek, Google Gemini, Alibaba, Baidu, Tencent, ByteDance, Zhipu, Moonshot, and more."
>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-blue-50 via-white to-indigo-50 py-16 sm:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto">
        <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 mb-6 leading-tight">
          Find the Most Cost-Effective
          <span class="text-blue-600">AI Token</span>
          Plan
        </h1>
        <p class="text-lg sm:text-xl text-gray-600 mb-8 leading-relaxed">
          Compare real-time pricing from 10+ top AI providers including OpenAI, Claude, DeepSeek, Gemini, and more. Always up to date, completely free.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="#providers" class="btn-primary text-lg py-3 px-8">
            View Price Comparison →
          </a>
          <a href="/tutorials" class="btn-secondary text-lg py-3 px-8">
            Getting Started
          </a>
        </div>
      </div>
      
      <div class="mt-12 grid grid-cols-3 gap-4 sm:gap-8 max-w-2xl mx-auto text-center">
        <div>
          <div class="text-3xl sm:text-4xl font-bold text-blue-600">10+</div>
          <div class="text-sm text-gray-500 mt-1">Providers</div>
        </div>
        <div>
          <div class="text-3xl sm:text-4xl font-bold text-green-600">50+</div>
          <div class="text-sm text-gray-500 mt-1">Models</div>
        </div>
        <div>
          <div class="text-3xl sm:text-4xl font-bold text-indigo-600">Real-time</div>
          <div class="text-sm text-gray-500 mt-1">Updates</div>
        </div>
      </div>
    </div>
  </section>

  <!-- AdSense Position 1 -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <div class="adsense-placeholder h-28 rounded-lg"></div>
  </section>

  <!-- Domestic Providers -->
  <section id="providers" class="py-12 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-3 mb-8">
        <span class="text-2xl">🇨🇳</span>
        <h2 class="text-2xl font-bold text-gray-900">AI APIs Available in China</h2>
        <span class="badge badge-success text-xs">Direct Access</span>
      </div>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
        {domesticProviders.map((provider) => (
          <a href={`/providers/${provider.id}`} class="provider-card group">
            <div class="flex items-center justify-between">
              <h3 class="font-bold text-gray-900 group-hover:text-blue-600 transition-colors">{provider.name}</h3>
              <span class={`badge text-xs ${provider.overallRank <= 3 ? 'badge-success' : 'bg-gray-100 text-gray-600'}`}>#{provider.overallRank}</span>
            </div>
            <p class="text-sm text-gray-500">{provider.name}</p>
            <div class="mt-3 space-y-1 text-sm">
              <div class="flex justify-between"><span class="text-gray-500">Input</span><span class="font-medium text-gray-900">{provider.pricing.input}</span></div>
              <div class="flex justify-between"><span class="text-gray-500">Output</span><span class="font-medium text-gray-900">{provider.pricing.output}</span></div>
            </div>
            <div class="mt-3 pt-3 border-t border-gray-100">
              <div class="flex items-center gap-2">
                <span class="text-green-600 text-xs font-medium">{provider.availabilityEN}</span>
                <span class="flex-1"></span>
                <span class="text-xs text-gray-400">Free Credits</span>
              </div>
              <p class="text-xs text-gray-500 mt-1">{provider.freeTierEN}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- International Providers -->
  <section class="py-12 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-3 mb-8">
        <span class="text-2xl">🌍</span>
        <h2 class="text-2xl font-bold text-gray-900">International AI APIs</h2>
        <span class="badge badge-warning text-xs">Proxy Required</span>
      </div>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
        {intlProviders.map((provider) => (
          <a href={`/providers/${provider.id}`} class="provider-card group">
            <div class="flex items-center justify-between">
              <h3 class="font-bold text-gray-900 group-hover:text-blue-600 transition-colors">{provider.name}</h3>
              <span class="badge bg-blue-100 text-blue-700 text-xs">#{provider.overallRank}</span>
            </div>
            <p class="text-sm text-gray-500">{provider.name}</p>
            <div class="mt-3 space-y-1 text-sm">
              <div class="flex justify-between"><span class="text-gray-500">Input</span><span class="font-medium text-gray-900">{provider.pricing.input}</span></div>
              <div class="flex justify-between"><span class="text-gray-500">Output</span><span class="font-medium text-gray-900">{provider.pricing.output}</span></div>
            </div>
            <div class="mt-3 pt-3 border-t border-gray-100">
              <div class="flex items-center gap-2">
                <span class={`text-xs font-medium ${provider.availabilityEN.includes('❌') ? 'text-red-500' : 'text-yellow-500'}`}>{provider.availabilityEN}</span>
                <span class="flex-1"></span>
                <span class="text-xs text-gray-400">Free Credits</span>
              </div>
              <p class="text-xs text-gray-500 mt-1">{provider.freeTierEN}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- AdSense Position 2 -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <div class="adsense-placeholder h-28 rounded-lg"></div>
  </section>

  <!-- Price Comparison Table -->
  <section class="py-12 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">💰 Token Price Comparison</h2>
      
      <div class="overflow-x-auto">
        <table class="table-token">
          <thead>
            <tr>
              <th>Provider</th><th>Popular Models</th><th>Input</th><th>Output</th><th>China Available</th><th>Free Tier</th><th></th>
            </tr>
          </thead>
          <tbody>
            {sortedProviders.map((p) => (
              <tr>
                <td class="font-semibold text-gray-900">{p.name}</td>
                <td class="text-gray-600">{p.models.slice(0, 2).join(', ')}</td>
                <td class="font-mono text-sm">{p.pricing.input}</td>
                <td class="font-mono text-sm">{p.pricing.output}</td>
                <td><span class={`badge text-xs ${p.availabilityEN.includes('✅') ? 'badge-success' : p.availabilityEN.includes('⚠️') ? 'badge-warning' : 'badge-danger'}`}>{p.availabilityEN}</span></td>
                <td class="text-xs text-gray-500">{p.freeTierEN}</td>
                <td><a href={`/providers/${p.id}`} class="text-blue-600 hover:text-blue-800 text-sm font-medium">View Details →</a></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-12 bg-gray-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-8 text-center">❓ Frequently Asked Questions</h2>
      
      <div class="space-y-6">
        <details class="bg-white rounded-lg border border-gray-200 p-5 group">
          <summary class="font-semibold text-gray-900 cursor-pointer list-none flex justify-between items-center">
            Which AI API is the cheapest?
            <span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="mt-3 text-gray-600 leading-relaxed">
            By absolute price, <strong>ByteDance Doubao</strong> and <strong>DeepSeek-V3</strong> are the cheapest. But considering model capability, <strong>DeepSeek</strong> offers the best value — currently the most recommended low-cost high-performance option.
          </p>
        </details>
        
        <details class="bg-white rounded-lg border border-gray-200 p-5 group">
          <summary class="font-semibold text-gray-900 cursor-pointer list-none flex justify-between items-center">
            Can I use OpenAI and Claude API in China?
            <span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="mt-3 text-gray-600 leading-relaxed">
            In theory yes, but a <strong>proxy service</strong> is required. Direct access from China is restricted or extremely slow. We recommend using domestic direct-access options (like DeepSeek, Zhipu GLM), or an <a href="/providers/openai" class="text-blue-600 underline">API proxy service</a>.
          </p>
        </details>
        
        <details class="bg-white rounded-lg border border-gray-200 p-5 group">
          <summary class="font-semibold text-gray-900 cursor-pointer list-none flex justify-between items-center">
            Is DeepSeek API actually usable? How is the quality?
            <span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="mt-3 text-gray-600 leading-relaxed">
            <strong>DeepSeek-V3</strong> and <strong>DeepSeek-R1</strong> have reached GPT-4 level capability, even stronger in coding and math reasoning. DeepSeek-R1 supports chain-of-thought output with transparent reasoning. The only downside is the ecosystem is not as rich as OpenAI's, but the price is a fraction of OpenAI's.
          </p>
        </details>
        
        <details class="bg-white rounded-lg border border-gray-200 p-5 group">
          <summary class="font-semibold text-gray-900 cursor-pointer list-none flex justify-between items-center">
            How do I apply for these AI APIs?
            <span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="mt-3 text-gray-600 leading-relaxed">
            The process is similar for all providers: Register account → Identity verification (domestic platforms) → Top up / buy resource pack → Get API Key → Start calling. See our <a href="/tutorials" class="text-blue-600 underline">tutorials</a> for specific guides.
          </p>
        </details>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 bg-blue-600">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold text-white mb-4">Ready to get started?</h2>
      <p class="text-blue-100 mb-8">Compare prices across all platforms and choose the AI plan that fits you best</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="#providers" class="bg-white text-blue-600 font-semibold py-3 px-8 rounded-lg hover:bg-blue-50 transition-colors">View Price Comparison</a>
        <a href="/tutorials" class="bg-blue-700 text-white font-semibold py-3 px-8 rounded-lg hover:bg-blue-800 transition-colors">Getting Started</a>
      </div>
    </div>
  </section>
</BaseLayout>
