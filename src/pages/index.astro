---
import BaseLayout from '../layouts/BaseLayout.astro';
import providers from '../data/providers.json';

const locale = 'en';

// Sort by overall rank
const sortedProviders = [...providers].sort((a, b) => a.overallRank - b.overallRank);
const domesticProviders = sortedProviders.filter(p => p.category === 'domestic');
const intlProviders = sortedProviders.filter(p => p.category === 'international');
const aggregatorProviders = sortedProviders.filter(p => p.category === 'aggregator');

// JSON-LD: FAQPage for homepage
const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Which AI API is cheapest for Chinese developers?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "DeepSeek offers the lowest prices at ¥1/1M tokens input, directly accessible from mainland China without a proxy. Google AI's Gemini 2.5 Flash is also very competitive at $0.016/1M."
      }
    },
    {
      "@type": "Question",
      "name": "Can I use OpenAI's API in China?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "OpenAI's API is blocked in mainland China. You need a proxy or VPN service to access it, which adds complexity and reliability concerns."
      }
    },
    {
      "@type": "Question",
      "name": "Which AI API has the best free tier?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Google AI (Gemini 2.0 Flash) offers unlimited free usage. DeepSeek gives $2 signup bonus, and OpenAI offers $5 free credit for new users."
      }
    }
  ]
};
---

<BaseLayout
