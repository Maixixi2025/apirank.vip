---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="AI API Tutorials - Getting Started | APIRank"
  description="Step-by-step guides to help you get started with AI APIs. Learn how to apply for API keys, make your first API call, and integrate AI into your projects."
>
  <div class="bg-gray-50 border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <nav class="flex items-center gap-2 text-sm text-gray-500">
        <a href="/" class="hover:text-blue-600">Home</a>
        <span>›</span>
        <span class="text-gray-900 font-medium">Tutorials</span>
      </nav>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="text-center mb-12">
      <h1 class="text-3xl font-bold text-gray-900 mb-3">Tutorials</h1>
      <p class="text-gray-600">Step-by-step guides to help you get started with AI APIs</p>
    </div>

    <div class="space-y-6">
      <a href="/providers/deepseek" class="block bg-white rounded-xl border border-gray-200 p-6 hover:border-blue-300 hover:shadow-md transition-all">
        <div class="flex items-center gap-4">
          <div class="text-3xl">🔑</div>
          <div>
            <h2 class="text-lg font-bold text-gray-900 mb-1">How to Get a DeepSeek API Key</h2>
            <p class="text-gray-500 text-sm">Step-by-step guide to register, verify, and get your DeepSeek API key in minutes.</p>
          </div>
        </div>
      </a>

      <a href="/providers/openai" class="block bg-white rounded-xl border border-gray-200 p-6 hover:border-blue-300 hover:shadow-md transition-all">
        <div class="flex items-center gap-4">
          <div class="text-3xl">🤖</div>
          <div>
            <h2 class="text-lg font-bold text-gray-900 mb-1">How to Use OpenAI API from China</h2>
            <p class="text-gray-500 text-sm">Learn how to access OpenAI API with or without a proxy service.</p>
          </div>
        </div>
      </a>

      <a href="/providers/anthropic" class="block bg-white rounded-xl border border-gray-200 p-6 hover:border-blue-300 hover:shadow-md transition-all">
        <div class="flex items-center gap-4">
          <div class="text-3xl">🧠</div>
          <div>
            <h2 class="text-lg font-bold text-gray-900 mb-1">Claude API Getting Started Guide</h2>
            <p class="text-gray-500 text-sm">Everything you need to know to start using Claude via API.</p>
          </div>
        </div>
      </a>
    </div>
  </div>
</BaseLayout>
